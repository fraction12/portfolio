---
type ProofSignal = {
  label: string;
  title: string;
  body: string;
  href: string;
};

interface Props {
  signals: ProofSignal[];
}

const { signals } = Astro.props;
---

<section class="proof-strip" aria-label="Proof points">
  {signals.map(signal => (
    <a class="proof-strip__item" href={signal.href}>
      <span>{signal.label}</span>
      <strong>{signal.title}</strong>
      <p>{signal.body}</p>
    </a>
  ))}
</section>

<style>
  .proof-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .proof-strip__item {
    display: grid;
    align-content: start;
    gap: 0.45rem;
    min-height: 150px;
    padding: 1.1rem 1.15rem 1.2rem;
    color: inherit;
    text-decoration: none;
    border-right: 1px solid var(--line);
    transition:
      background var(--motion-fast) ease,
      border-color var(--motion-fast) ease;
  }

  .proof-strip__item:last-child {
    border-right: 0;
  }

  .proof-strip__item:hover {
    background: var(--surface-card);
  }

  .proof-strip__item span {
    color: var(--dim);
    font-size: var(--type-caption-size);
    font-weight: 700;
  }

  .proof-strip__item strong {
    color: var(--ivory);
    font-size: 1rem;
    line-height: 1.35;
  }

  .proof-strip__item p {
    color: var(--ivory-2);
    font-size: var(--type-small-size);
    line-height: 1.55;
  }

  @media (max-width: 860px) {
    .proof-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .proof-strip__item:nth-child(2n) {
      border-right: 0;
    }

    .proof-strip__item:nth-child(n + 3) {
      border-top: 1px solid var(--line);
    }
  }

  @media (max-width: 560px) {
    .proof-strip {
      grid-template-columns: 1fr;
    }

    .proof-strip__item,
    .proof-strip__item:nth-child(2n) {
      min-height: auto;
      border-right: 0;
    }

    .proof-strip__item + .proof-strip__item {
      border-top: 1px solid var(--line);
    }
  }
</style>
