---
const email = 'dushyantgarg3@gmail.com';
---

<div class="contact">
  <p>
    For product roles, startup work, or focused consulting, email is the cleanest way to reach me.
  </p>
  <a class="btn btn--primary" href={`mailto:${email}`}>Email Dushyant</a>
  <p class="contact__address">
    {email}
  </p>
</div>

<style>
  .contact {
    display: grid;
    gap: 0.9rem;
    max-width: 58ch;
  }

  .contact p {
    color: var(--ivory-2);
    line-height: 1.65;
  }

  .contact .btn {
    justify-self: start;
  }

  .contact__address {
    color: var(--dim);
    font-family: var(--font-display);
    font-size: var(--type-small-size);
  }

  @media (max-width: 520px) {
    .contact .btn {
      width: 100%;
    }
  }
</style>
