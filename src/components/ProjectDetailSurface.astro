---
import type { ToolDetail } from '../config/tool-details';

interface Props {
  detail: ToolDetail;
  mode?: 'inline' | 'page';
  selected?: boolean;
}

const { detail, mode = 'inline', selected = false } = Astro.props;
const { artifact } = detail;
const hasReadyMedia = detail.demo.status === 'ready' && Boolean(detail.demo.src || detail.demo.embedUrl);
const mediaHeading = detail.demo.type === 'image' ? 'Preview' : 'Demo';
const mediaCtaLabel = detail.demo.type === 'image' ? 'View preview' : 'Watch demo';
const panelId = `project-${detail.slug}`;
---

<article
  id={panelId}
  class:list={['project-surface', `project-surface--${mode}`]}
  data-project-panel={mode === 'inline' ? detail.slug : undefined}
  hidden={mode === 'inline' && !selected}
>
  <header class="project-surface__hero">
    <div class="project-surface__copy">
      {mode === 'page' && <a class="project-surface__back" href="/tools">Back to work</a>}
      <p class="project-surface__kicker">{detail.categoryLabel}</p>
      <h1>{artifact.name}</h1>
      <p class="project-surface__tagline">{detail.tagline}</p>
      <p class="project-surface__summary">{detail.summary}</p>
    </div>

    <aside class="project-surface__facts" aria-label={`${artifact.name} project facts`}>
      <div>
        <span>Audience</span>
        <strong>{detail.audience}</strong>
      </div>
      <div>
        <span>Status</span>
        <strong>{detail.statusNote}</strong>
      </div>
      <div>
        <span>Stack</span>
        <strong>{artifact.stack}</strong>
      </div>
    </aside>
  </header>

  <div class="project-surface__body">
    <section class="project-surface__section project-surface__section--actions" aria-label={`${artifact.name} actions`}>
      <div class="project-surface__label">
        <span>Open</span>
      </div>
      <div class="project-surface__actions">
        {hasReadyMedia && <a class="btn btn--primary" href={`#${panelId}-media`}>{mediaCtaLabel}</a>}
        {detail.links.map(link => (
          <a
            class="btn btn--ghost"
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        ))}
        {mode === 'inline' && <a class="project-surface__text-link" href={detail.detailPath}>Dedicated page</a>}
        {detail.links.length === 0 && (
          <p class="project-surface__quiet">No public repository or product surface is attached yet.</p>
        )}
      </div>
    </section>

    {hasReadyMedia && (
      <section id={`${panelId}-media`} class="project-surface__section" aria-labelledby={`${panelId}-media-heading`}>
        <div class="project-surface__label">
          <h2 id={`${panelId}-media-heading`}>{mediaHeading}</h2>
        </div>
        <div class="project-surface__main">
          {detail.demo.type === 'video' && detail.demo.embedUrl && (
            <a class="project-media project-media--link" href={detail.demo.embedUrl} target="_blank" rel="noopener noreferrer">
              <span class="project-media__play" aria-hidden="true"></span>
              <span>
                <strong>{detail.demo.label}</strong>
                <small>{detail.demo.caption}</small>
              </span>
            </a>
          )}

          {detail.demo.type === 'video' && detail.demo.src && (
            <figure class="project-media">
              <video controls preload="none" playsinline poster={detail.demo.poster} aria-label={detail.demo.label}>
                <source src={detail.demo.src} type="video/mp4" />
                {detail.demo.transcript && <track kind="descriptions" srclang="en" label="Transcript" src={detail.demo.transcript} />}
              </video>
              <figcaption>{detail.demo.caption}</figcaption>
            </figure>
          )}

          {detail.demo.type === 'image' && detail.demo.src && (
            <figure class="project-media project-media--image">
              <img src={detail.demo.src} alt={detail.demo.alt ?? detail.demo.label} width="1280" height="800" loading="lazy" decoding="async" />
              <figcaption>{detail.demo.caption}</figcaption>
            </figure>
          )}
        </div>
      </section>
    )}

    <section class="project-surface__section" aria-labelledby={`${panelId}-problem-heading`}>
      <div class="project-surface__label">
        <h2 id={`${panelId}-problem-heading`}>Problem</h2>
      </div>
      <div class="project-surface__main project-surface__prose project-surface__prose--lead">
        <p>{detail.problem}</p>
      </div>
    </section>

    <section class="project-surface__section" aria-labelledby={`${panelId}-story-heading`}>
      <div class="project-surface__label">
        <h2 id={`${panelId}-story-heading`}>Story</h2>
      </div>
      <div class="project-surface__main project-surface__story">
        {detail.sections.map(section => (
          <article>
            <h3>{section.title}</h3>
            {section.body.map(paragraph => <p>{paragraph}</p>)}
          </article>
        ))}
      </div>
    </section>
  </div>
</article>

<style>
  .project-surface {
    border-top: 1px solid var(--line);
    color: var(--ivory);
  }

  .project-surface--inline {
    margin-top: clamp(1.5rem, 4vw, 2.5rem);
    padding-top: clamp(1.5rem, 4vw, 2.5rem);
  }

  .project-surface--page {
    padding-bottom: clamp(4rem, 8vw, 7rem);
  }

  .project-surface__hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(250px, 340px);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
    padding: clamp(2.5rem, 7vw, 5.5rem) 0;
  }

  .project-surface--inline .project-surface__hero {
    padding-top: 0;
  }

  .project-surface__back,
  .project-surface__text-link {
    display: inline-flex;
    color: var(--signal);
    font-size: var(--type-small-size);
    font-weight: 700;
    text-decoration: none;
  }

  .project-surface__back {
    margin-bottom: 1.5rem;
  }

  .project-surface__back:hover,
  .project-surface__text-link:hover {
    color: var(--signal-hov);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .project-surface__kicker {
    color: var(--dim);
    font-size: var(--type-small-size);
    font-weight: 700;
    margin-bottom: 0.9rem;
  }

  .project-surface h1 {
    font-size: clamp(2.8rem, 8vw, 6.5rem);
    line-height: 0.94;
    max-width: 12ch;
    margin-bottom: 1.25rem;
    overflow-wrap: anywhere;
    text-wrap: balance;
  }

  .project-surface__tagline {
    color: var(--ivory);
    font-size: clamp(1.2rem, 2.2vw, 1.65rem);
    line-height: 1.45;
    max-width: 38ch;
    margin-bottom: 1.15rem;
  }

  .project-surface__summary {
    color: var(--ivory-2);
    font-size: clamp(1rem, 1.45vw, 1.12rem);
    line-height: 1.7;
    max-width: 68ch;
  }

  .project-surface__facts {
    display: grid;
    align-content: start;
    border-top: 1px solid var(--line);
  }

  .project-surface__facts div {
    display: grid;
    gap: 0.4rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--line);
  }

  .project-surface__facts span,
  .project-surface__label {
    color: var(--dim);
    font-size: var(--type-small-size);
    font-weight: 700;
  }

  .project-surface__facts strong {
    color: var(--ivory);
    font-size: 0.98rem;
    font-weight: 400;
    line-height: 1.55;
  }

  .project-surface__body {
    border-top: 1px solid var(--line);
  }

  .project-surface__section {
    display: grid;
    grid-template-columns: minmax(150px, 220px) minmax(0, 1fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    padding: clamp(1.75rem, 4.8vw, 3.25rem) 0;
    border-bottom: 1px solid var(--line);
  }

  .project-surface__section--actions {
    align-items: center;
  }

  .project-surface__label h2,
  .project-surface__label span {
    font-size: 1rem;
    line-height: 1.4;
  }

  .project-surface__main {
    min-width: 0;
  }

  .project-surface__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .project-surface__quiet {
    color: var(--dim);
    font-size: var(--type-small-size);
  }

  .project-surface__prose p,
  .project-surface__story p {
    color: var(--ivory-2);
    line-height: 1.7;
  }

  .project-surface__prose--lead p {
    max-width: 68ch;
    font-size: clamp(1.06rem, 1.7vw, 1.22rem);
  }

  .project-surface__story {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .project-surface__story article {
    min-width: 0;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .project-surface__story h3 {
    font-size: 1.02rem;
    margin-bottom: 0.65rem;
  }

  .project-surface__story p + p {
    margin-top: 0.6rem;
  }

  .project-media {
    display: grid;
    overflow: hidden;
    border: 1px solid var(--line);
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--surface-raised) 78%, var(--signal-dim)), transparent 70%),
      var(--ink-1);
    color: var(--ivory);
  }

  .project-media video,
  .project-media img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    object-position: center;
    background: var(--ink-1);
  }

  .project-media--image img {
    object-fit: contain;
  }

  .project-media figcaption {
    padding: 0.85rem 1rem 1rem;
    color: var(--dim);
    font-size: var(--type-small-size);
  }

  .project-media--link {
    grid-template-columns: 80px minmax(0, 1fr);
    gap: clamp(1rem, 4vw, 2rem);
    align-items: end;
    padding: clamp(1.25rem, 4vw, 2rem);
    text-decoration: none;
  }

  .project-media--link:hover {
    border-color: var(--signal);
  }

  .project-media strong {
    display: block;
    font-size: clamp(1.35rem, 3vw, 2.25rem);
    line-height: 1.08;
    margin: 0.25rem 0 0.7rem;
  }

  .project-media small {
    display: block;
    max-width: 58ch;
    color: var(--ivory-2);
    font-size: 1rem;
    line-height: 1.6;
  }

  .project-media__play {
    position: relative;
    width: 64px;
    aspect-ratio: 1;
    border: 1px solid var(--line-2);
    border-radius: 999px;
    background: var(--surface-raised);
  }

  .project-media__play::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 53%;
    width: 0;
    height: 0;
    border-top: 9px solid transparent;
    border-bottom: 9px solid transparent;
    border-left: 14px solid var(--ivory);
    transform: translate(-50%, -50%);
  }

  @media (max-width: 980px) {
    .project-surface__story {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 800px) {
    .project-surface__hero,
    .project-surface__section {
      grid-template-columns: 1fr;
    }

    .project-surface h1 {
      max-width: 100%;
    }

    .project-media--link {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .project-surface__actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
