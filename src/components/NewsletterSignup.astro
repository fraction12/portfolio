---
const { className = '' } = Astro.props;
---

<section class:list={["newsletter", className]} aria-label="Newsletter signup">
  <p class="newsletter-value">
    Get practical notes on building with AI agents, shipping fast, and learning in public.
  </p>
  <a class="badge-link" href="https://dushyantg.substack.com" target="_blank" rel="noopener noreferrer" aria-label="Substack subscribers">
    <img src="https://img.shields.io/badge/Substack-subscribers%20available-6366f1?style=flat-square" alt="Substack subscribers" loading="lazy" />
  </a>

  <form
    class="newsletter-form"
    action="https://dushyantg.substack.com/api/v1/free"
    method="post"
    target="_blank"
    rel="noopener noreferrer"
  >
    <label class="sr-only" for="newsletter-email">Email address</label>
    <input
      id="newsletter-email"
      name="email"
      type="email"
      autocomplete="email"
      placeholder="you@domain.com"
      required
    />
    <button type="submit">Subscribe</button>
  </form>
</section>
