---
import Button from './Button.astro';
const { className = '' } = Astro.props;
---

<section class:list={["newsletter", className]} aria-label="Newsletter signup">
  <p class="newsletter__value">
    Get new essays by email.
  </p>

  <form
    class="newsletter__form"
    action="https://dushyantg.substack.com/api/v1/free"
    method="post"
    target="_blank"
    rel="noopener noreferrer"
  >
    <label class="sr-only" for="newsletter-email">Email address</label>
    <input
      id="newsletter-email"
      class="field"
      name="email"
      type="email"
      autocomplete="email"
      placeholder="you@domain.com"
      required
    />
    <Button type="submit">Subscribe</Button>
  </form>
</section>

<style>
  .newsletter {
    display: grid;
    gap: 1rem;
    max-width: 520px;
  }

  .newsletter__value {
    color: var(--ivory-2);
    line-height: 1.6;
  }

  .newsletter__form {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
  }

  @media (max-width: 560px) {
    .newsletter__form {
      grid-template-columns: 1fr;
    }
  }
</style>
