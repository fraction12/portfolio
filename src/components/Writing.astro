---
import WritingRow from './WritingRow.astro';
import { fetchEssays, type Essay } from '../lib/data/substack';

interface Props {
  limit?: number;
}

const { limit } = Astro.props;

// Shared fetcher: 5s timeout, snapshot fallback on failure.
const essays: Essay[] = await fetchEssays();
const visiblePosts = typeof limit === 'number' ? essays.slice(0, limit) : essays;
const hasError = essays.length === 0;
---

<div id="writing">
  {visiblePosts.length > 0 ? (
    <div class="writing-list">
      {visiblePosts.map(post => <WritingRow essay={post} />)}
    </div>
  ) : (
    <div class="writing-empty">
      <p>{hasError ? 'Could not load writing from Substack right now.' : 'No writing published yet.'}</p>
      <a href="https://dushyantg.substack.com" target="_blank" rel="noopener noreferrer">Open Substack</a>
    </div>
  )}
</div>

<style>
  .writing-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--line);
  }
  .writing-empty {
    border: 1px dashed var(--line);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    color: var(--dim);
  }
  .writing-empty a {
    display: inline-block;
    margin-top: 0.7rem;
    color: var(--signal);
    text-decoration: none;
  }
  .writing-empty a:hover { text-decoration: underline; text-underline-offset: 3px; }
</style>
