---
const FEED_URL = 'https://dushyantg.substack.com/feed';

interface FeedPost {
  title: string;
  link: string;
  description: string;
  dateLabel: string;
  readTimeMinutes: number;
}

const decodeXml = (input = '') =>
  input
    .replaceAll('&amp;', '&')
    .replaceAll('&lt;', '<')
    .replaceAll('&gt;', '>')
    .replaceAll('&quot;', '"')
    .replaceAll('&#39;', "'");

const stripHtml = (input = '') =>
  decodeXml(input)
    .replace(/<!\[CDATA\[([\s\S]*?)\]\]>/g, '$1')
    .replace(/<[^>]*>/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();

const getTagValue = (itemXml: string, tagName: string) => {
  const match = itemXml.match(new RegExp(`<${tagName}[^>]*>([\\s\\S]*?)<\\/${tagName}>`, 'i'));
  return match?.[1]?.trim() ?? '';
};

const getReadTimeMinutes = (content: string) => {
  const words = stripHtml(content).split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 200));
};

const formatDate = (pubDate: string) => {
  const parsed = new Date(pubDate);
  if (Number.isNaN(parsed.getTime())) return 'Unknown date';

  return new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric'
  }).format(parsed);
};

const parseFeed = (xml: string): FeedPost[] => {
  const itemMatches = [...xml.matchAll(/<item>([\s\S]*?)<\/item>/gi)];

  return itemMatches
    .map((match) => {
      const itemXml = match[1] ?? '';
      const title = stripHtml(getTagValue(itemXml, 'title'));
      const link = stripHtml(getTagValue(itemXml, 'link'));
      const descriptionRaw = getTagValue(itemXml, 'description');
      const contentRaw =
        getTagValue(itemXml, 'content:encoded') ||
        getTagValue(itemXml, 'content') ||
        descriptionRaw;

      return {
        title,
        link,
        description: stripHtml(descriptionRaw),
        dateLabel: formatDate(getTagValue(itemXml, 'pubDate')),
        readTimeMinutes: getReadTimeMinutes(contentRaw)
      };
    })
    .filter((post) => post.title && post.link);
};

let posts: FeedPost[] = [];
let hasError = false;

try {
  const response = await fetch(FEED_URL);
  if (!response.ok) {
    throw new Error(`Feed request failed: ${response.status}`);
  }

  const xml = await response.text();
  posts = parseFeed(xml);
} catch (error) {
  hasError = true;
  console.error('Failed to fetch Substack feed:', error);
}
---

<section id="writing">
  {posts.length > 0 ? (
    <div class="writing-list">
      {posts.map((post, index) => (
        <article class="writing-item reveal" style={`--reveal-delay: ${(index + 1) * 0.05}s;`}>
          <div>
            <h3>{post.title}</h3>
            <p class="date">{post.dateLabel} · {post.readTimeMinutes} min read</p>
            <p class="writing-description">{post.description}</p>
            <a class="writing-read-link" href={post.link} target="_blank" rel="noopener noreferrer">
              Read on Substack →
            </a>
          </div>
        </article>
      ))}
    </div>
  ) : (
    <div class="writing-empty">
      <p>{hasError ? 'Could not load writing from Substack right now.' : 'No writing published yet.'}</p>
      <a href="https://dushyantg.substack.com" target="_blank" rel="noopener noreferrer">Visit Substack →</a>
    </div>
  )}
</section>
