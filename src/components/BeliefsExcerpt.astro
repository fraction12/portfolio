---
import { BELIEFS } from '../data/beliefs';
const featured = BELIEFS.filter(b => b.homeFeatured);
---

<div class="excerpt">
  {featured.map(b => (
    <article class="card card--belief">
      <h4>// Rule · {b.n}</h4>
      <p set:html={b.text.replace(/\*(.+?)\*/g, '<em>$1</em>')}></p>
    </article>
  ))}
</div>

<a class="more-link" href="/beliefs">Read all four →</a>

<style>
  .excerpt {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .card--belief :global(h4) { color: var(--signal); }
  .card--belief :global(p) {
    font-family: var(--font-display);
    font-size: 1.05rem;
    line-height: 1.45;
  }
  .card--belief :global(p em) {
    font-style: italic;
    color: var(--signal);
    font-weight: 500;
  }
  .more-link {
    display: inline-block;
    margin-top: 14px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--signal);
    text-decoration: none;
  }
  .more-link:hover { text-decoration: underline; text-underline-offset: 3px; }

  @media (max-width: 640px) { .excerpt { grid-template-columns: 1fr; } }
</style>
