---
import type { Artifact } from '../config/packages';

interface Props {
  artifact: Artifact;
  metric: string | null;
  metricPlaceholder?: string;
}
const { artifact, metric, metricPlaceholder } = Astro.props;

const githubUrl = artifact.repo ? `https://github.com/${artifact.repo}` : null;
const install = artifact.installCommand ?? '';
// Detect the "# comment-style" install placeholder — display the command but mute it
const isComment = install.trim().startsWith('#');
const isDev = artifact.status === 'dev';
---

<article class:list={['card card--tool', { 'is-dev': isDev }]}>
  <div class="tool-head">
    <span class="tool-name">{artifact.name}</span>
    <span class="tool-meta">{artifact.stack}</span>
  </div>
  <p class="tool-desc">{artifact.description}</p>

  {install && (
    <div class="tool-install">
      <span class="prompt">$</span>{isComment
        ? <span class="cmt">{install}</span>
        : install}
    </div>
  )}

  <div class="tool-foot">
    {githubUrl && <a href={githubUrl} target="_blank" rel="noopener">github ↗</a>}
    {artifact.url && (
      <>
        {githubUrl && <span class="sep">·</span>}
        <a href={artifact.url} target="_blank" rel="noopener">{artifact.url.replace(/^https?:\/\//, '')} ↗</a>
      </>
    )}
    {metric
      ? <>{(githubUrl || artifact.url) && <span class="sep">·</span>}<span class="metric">{metric}</span></>
      : metricPlaceholder
        ? <>{(githubUrl || artifact.url) && <span class="sep">·</span>}<span class="metric ph">{metricPlaceholder}</span></>
        : null}
  </div>
</article>

<style>
  .card--tool {
    padding: 22px 24px 20px;
    gap: 0;
  }

  .tool-head {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 8px;
    gap: 12px;
  }
  .tool-name {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: var(--ivory);
    letter-spacing: -0.005em;
  }
  .tool-meta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--dim);
    letter-spacing: 0.04em;
  }
  .tool-desc {
    color: var(--ivory-2);
    font-size: 15px;
    line-height: 1.6;
    max-width: 62ch;
    margin: 0 0 14px;
  }
  .tool-install {
    font-family: var(--font-mono);
    font-size: 13.5px;
    background: var(--ink-terminal);
    border: 1px solid var(--line-2);
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    color: var(--ivory);
    margin-bottom: 14px;
    overflow-x: auto;
    white-space: nowrap;
  }
  .tool-install .cmt { color: var(--dim); font-style: italic; }
  .tool-install .prompt { color: var(--signal); margin-right: 6px; user-select: none; }
  .card--tool.is-dev .tool-install { border-style: dashed; }

  .tool-foot {
    display: flex; gap: 16px; flex-wrap: wrap;
    font-family: var(--font-mono); font-size: 12.5px; color: var(--dim);
  }
  .tool-foot a {
    color: var(--signal);
    text-decoration: none;
    transition: text-decoration-color var(--motion-fast) ease;
  }
  .tool-foot a:hover { text-decoration: underline; text-underline-offset: 3px; }
  .tool-foot .sep { color: var(--dim-2); }
  .tool-foot .metric { color: var(--signal); }
  .tool-foot .metric.ph { color: var(--dim-2); font-style: italic; }

  @media (max-width: 640px) {
    .card--tool { padding: 18px 18px 16px; }
    .tool-head { flex-direction: column; gap: 2px; align-items: flex-start; }
  }
</style>
