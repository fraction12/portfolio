---
const projects = [
  {
    name: '📋 agentplan',
    description:
      "AI agents kept duplicating work on my machine, so I built a shared to-do system with dependencies, priorities, and atomic claims. I pushed 51 commits in one day, built it with pure Python stdlib, and shipped it to coordinate multiple agents cleanly.",
    tech: ['Python', 'SQLite', 'CLI', 'PyPI'],
    amberTech: ['PyPI'],
    stats: [
      { label: '⭐', id: 'agentplan-stars' },
      { label: '✅', id: 'agentplan-tests', suffix: ' tests' },
      { label: '📦 v', id: 'agentplan-version' },
    ],
  },
  {
    name: '🏆 OpenRank',
    description:
      "I needed a real benchmark for AI agents, not toy prompts, so I built daily puzzles with a live leaderboard and server-side timing. The key insight: agents can self-report anything, but they can't fake timestamps.",
    tech: ['Astro', 'TypeScript', 'Supabase', 'Live'],
    amberTech: ['Live'],
    stats: [
      { type: 'link', label: 'open-rank.com ↗', href: 'https://open-rank.com' },
      { label: '⭐', id: 'openrank-stars' },
    ],
  },
  {
    name: '🖥 ClawK',
    description:
      'A native macOS menu bar app for OpenClaw so background AI runs are actually observable. It was my first SwiftUI app and proved that developer tooling feels radically better when it lives directly on your desktop.',
    tech: ['Swift', 'SwiftUI', 'macOS'],
    amberTech: [],
    stats: [{ label: '⭐', id: 'clawk-stars' }],
  },
  {
    name: '🔔 agentrem',
    description:
      "Agents lose context between sessions, so I built persistent reminders with a CLI and MCP server. I rewrote it from Python to TypeScript overnight, shipped six versions between midnight and 4am, and learned docs are the real distribution channel for MCP tools.",
    tech: ['TypeScript', 'SQLite', 'MCP', 'npm'],
    amberTech: ['npm'],
    stats: [{ label: '⭐', id: 'agentrem-stars' }],
  },
  {
    name: '⚡ TradeSpec AI',
    description:
      'After watching contractors bid from handwritten notes where one misread digit could cost thousands, I started building an AI workflow for faster and safer trade estimates. Still in development.',
    tech: ['AI/ML', 'Node.js', 'SaaS'],
    amberTech: ['SaaS'],
    stats: [{ type: 'text', value: '🏗 In Development' }],
  },
  {
    name: '🧠 AgentSense',
    description:
      "Started as a 'what if' experiment: give an agent durable memory using automatic entity extraction and a zero-cost knowledge graph. The most useful output wasn't just facts, it was relationship context across people and projects.",
    tech: ['TypeScript', 'SQLite', 'FTS5'],
    amberTech: [],
    stats: [{ label: '⭐', id: 'agentsense-stars' }],
  },
  {
    name: '🎮 Chronoblast',
    description:
      'A roguelike shooter with time-loop mechanics built over seven months in Unreal on a 7-person team. I handled weapon loot systems, procedural level generation, and boss mechanics in C++, and it became my biggest lesson in shipping game systems.',
    tech: ['Unreal Engine 4', 'C++', 'Game Dev'],
    amberTech: [],
    stats: [
      { type: 'text', value: '🎓 Full Sail University' },
      { type: 'link', label: 'Play on itch.io ↗', href: 'https://chozofs.itch.io/chronoblast' },
    ],
  },
];
---
<section id="projects">
  <div class="projects-grid">
    {projects.map((project, index) => (
      <article class="card reveal" style={`--reveal-delay: ${(0.05 + index * 0.05).toFixed(2)}s;`}>
        <h3>{project.name}</h3>
        <p class="desc">{project.description}</p>
        <div class="pills">
          {project.tech.map((tech) => (
            <span class:list={["pill", project.amberTech.includes(tech) && 'amber']}>{tech}</span>
          ))}
        </div>
        <div class="stats">
          {project.stats.map((stat) => {
            if (stat.type === 'link') {
              return (
                <a href={stat.href} target="_blank" rel="noopener" class="stat-link">
                  {stat.label}
                </a>
              );
            }

            if (stat.type === 'text') {
              return <span>{stat.value}</span>;
            }

            return (
              <span>
                {stat.label} <span id={stat.id}>—</span>
                {stat.suffix ?? ''}
              </span>
            );
          })}
        </div>
      </article>
    ))}
  </div>
</section>
