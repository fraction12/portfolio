---
import Card from './Card.astro';
import Pill from './Pill.astro';
const projects = [
  {
    name: '🥔 Potato',
    description:
      'A terminal cockpit for coding agents. Run Claude, Codex, or other agents side by side in real PTYs, give them roles, and let them coordinate through a built-in MCP server.',
    tech: ['Rust', 'ratatui', 'MCP', 'Terminal'],
    amberTech: ['MCP'],
    badges: [
      {
        label: 'GitHub stars',
        href: 'https://github.com/fraction12/potato-v3',
        img: 'https://img.shields.io/github/stars/fraction12/potato-v3?style=flat-square&color=6366f1&label=stars'
      }
    ]
  },
  {
    name: '📋 agentplan',
    description:
      "AI agents kept duplicating work on my machine, so I built a shared to-do system with dependencies, priorities, and atomic claims.",
    tech: ['Python', 'SQLite', 'CLI', 'PyPI'],
    amberTech: ['PyPI'],
    badges: [
      {
        label: 'PyPI version',
        href: 'https://pypi.org/project/agentplan/',
        img: 'https://img.shields.io/pypi/v/agentplan?style=flat-square&color=6366f1&label=PyPI'
      },
      {
        label: 'GitHub stars',
        href: 'https://github.com/fraction12/agentplan',
        img: 'https://img.shields.io/github/stars/fraction12/agentplan?style=flat-square&color=6366f1&label=stars'
      }
    ]
  },
  {
    name: '🏆 OpenRank',
    description: 'Daily puzzles for AI agents with a live leaderboard and server-side timing to enforce integrity.',
    tech: ['Astro', 'TypeScript', 'Supabase', 'Live'],
    amberTech: ['Live'],
    badges: [
      {
        label: 'GitHub stars',
        href: 'https://github.com/fraction12/open-rank',
        img: 'https://img.shields.io/github/stars/fraction12/open-rank?style=flat-square&color=6366f1&label=stars'
      }
    ],
    links: [{ label: 'open-rank.com ↗', href: 'https://open-rank.com' }]
  },
  {
    name: '🖥 ClawK',
    description: 'Native macOS menu bar app for OpenClaw so background AI runs are observable in real time.',
    tech: ['Swift', 'SwiftUI', 'macOS'],
    amberTech: [],
    badges: [{ label: 'GitHub stars', href: 'https://github.com/fraction12/ClawK', img: 'https://img.shields.io/github/stars/fraction12/ClawK?style=flat-square&color=6366f1&label=stars' }]
  },
  {
    name: '🔔 agentrem',
    description: 'Persistent reminders for AI agents with CLI + MCP server; rewritten in TypeScript and shipped fast.',
    tech: ['TypeScript', 'SQLite', 'MCP', 'npm'],
    amberTech: ['npm'],
    badges: [
      {
        label: 'npm downloads',
        href: 'https://www.npmjs.com/package/agentrem',
        img: 'https://img.shields.io/npm/dm/agentrem?style=flat-square&color=6366f1&label=npm%20downloads%2Fmo'
      },
      {
        label: 'GitHub stars',
        href: 'https://github.com/fraction12/agentrem',
        img: 'https://img.shields.io/github/stars/fraction12/agentrem?style=flat-square&color=6366f1&label=stars'
      }
    ]
  },
  {
    name: '🏢 Agent Office',
    description: 'What if you could watch your AI agents live — not logs, not dashboards, but actually see them? An OpenClaw-native spatial interface built in Godot.',
    tech: ['Godot 4', 'GDScript', 'OpenClaw', 'WebSocket'],
    amberTech: ['OpenClaw'],
    badges: [],
    text: '🔒 Private · In Development'
  },
  {
    name: '⚡ TradeSpec AI',
    description: 'AI workflow for faster, safer trade estimates based on messy contractor source inputs.',
    tech: ['AI/ML', 'Node.js', 'SaaS'],
    amberTech: ['SaaS'],
    badges: [],
    text: '🏗 In Development'
  },
  {
    name: '🧠 AgentSense',
    description: 'Durable memory for agents using automatic entity extraction + relationship-aware context.',
    tech: ['TypeScript', 'SQLite', 'FTS5'],
    amberTech: [],
    badges: [{ label: 'GitHub stars', href: 'https://github.com/fraction12/agentsense', img: 'https://img.shields.io/github/stars/fraction12/agentsense?style=flat-square&color=6366f1&label=stars' }]
  },
  {
    name: '🎮 Chronoblast',
    description: 'Roguelike shooter with time-loop mechanics built in Unreal on a 7-person team over 7 months.',
    tech: ['Unreal Engine 4', 'C++', 'Game Dev'],
    amberTech: [],
    badges: [],
    text: '🎓 Full Sail University',
    links: [{ label: 'Play on itch.io ↗', href: 'https://chozofs.itch.io/chronoblast' }]
  }
];
---
<div id="projects">
  <div class="projects-grid">
    {projects.map((project, index) => (
      <Card variant="project" className="reveal" style={`--reveal-delay: ${(0.05 + index * 0.05).toFixed(2)}s;`}>
        <h3>{project.name}</h3>
        <p class="desc">{project.description}</p>
        <div class="pills">
          {project.tech.map((tech) => (
            <Pill variant={project.amberTech.includes(tech) ? 'signal' : 'dim'}>{tech}</Pill>
          ))}
        </div>

        <div class="stats">
          {project.badges.map((badge) => (
            <a href={badge.href} target="_blank" rel="noopener" class="badge-link" aria-label={badge.label}>
              <img src={badge.img} alt={badge.label} loading="lazy" />
            </a>
          ))}
          {project.links?.map((link) => (
            <a href={link.href} target="_blank" rel="noopener" class="stat-link">{link.label}</a>
          ))}
          {project.text && <span>{project.text}</span>}
        </div>
      </Card>
    ))}
  </div>
</div>
