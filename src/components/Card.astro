---
type Variant = 'project' | 'writing' | 'belief' | 'hub' | 'spotlight';
interface Props {
  variant?: Variant;
  as?: 'article' | 'a' | 'div';
  href?: string;
  className?: string;
  style?: string;
}
const { variant, as = 'article', href, className = '', style = '' } = Astro.props;
const classes = ['card', variant && `card--${variant}`, className].filter(Boolean).join(' ');
---
{as === 'a' || href ? (
  <a class={classes} href={href} style={style}><slot /></a>
) : as === 'div' ? (
  <div class={classes} style={style}><slot /></div>
) : (
  <article class={classes} style={style}><slot /></article>
)}
