---
import type { Essay } from '../lib/data';
import { isSafeEssayLink } from '../lib/data/substack';

interface Props { essay: Essay }
const { essay } = Astro.props;
const href = isSafeEssayLink(essay.link) ? essay.link : 'https://dushyantg.substack.com';

function shortDate(d: Date): string {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<a class="w-row" href={href} target="_blank" rel="noopener noreferrer">
  <span class="w-date">{shortDate(essay.publishedAt)}</span>
  <span class="w-title">{essay.title}</span>
  <span class="w-time">{essay.readTimeMinutes} min</span>
</a>

<style>
  .w-row {
    display: grid; grid-template-columns: 78px 1fr 60px;
    gap: 16px; padding: 14px 0;
    border-bottom: 1px solid var(--line);
    text-decoration: none; color: inherit; align-items: baseline;
    transition: color var(--motion-fast) ease, border-color var(--motion-fast) ease;
  }
  .w-row:last-child { border-bottom: 0; }
  .w-row:hover .w-title { color: var(--signal); }
  .w-date { font-size: 13px; color: var(--dim); }
  .w-title { color: var(--ivory); font-weight: 400; transition: color .2s; }
  .w-time { font-size: 13px; color: var(--dim); text-align: right; }

  @media (max-width: 640px) {
    .w-row { grid-template-columns: 1fr; gap: 2px; }
    .w-time { text-align: left; }
  }
</style>
