---
import type { Artifact } from '../config/packages';

interface Props {
  artifact: Artifact;
  kicker?: string;
}
const { artifact, kicker = 'Featured' } = Astro.props;

const gh = artifact.repo ? `https://github.com/${artifact.repo}` : null;
---

<article class="card card--spotlight reveal">
  <p class="kicker">
    {kicker} <span class="sep" aria-hidden="true">·</span> {artifact.category.replace(/-/g, ' ')}
  </p>
  <h2 class="title">{artifact.name}</h2>
  <p class="copy">{artifact.description}</p>

  <div class="actions">
    {gh && <a class="link" href={gh} target="_blank" rel="noopener">See on GitHub ↗</a>}
    {artifact.url && (
      <>
        {gh && <span class="sep" aria-hidden="true">·</span>}
        <a class="link" href={artifact.url} target="_blank" rel="noopener">
          {artifact.url.replace(/^https?:\/\//, '')} ↗
        </a>
      </>
    )}
    {artifact.installCommand && !artifact.installCommand.trim().startsWith('#') && (
      <code class="install"><span class="prompt">$</span> {artifact.installCommand}</code>
    )}
  </div>
</article>

<style>
  .card--spotlight .kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .card--spotlight .kicker .sep { color: var(--dim-2); }

  .actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
    margin-top: 8px;
  }
  .actions .sep { color: var(--dim-2); }
  .actions .install {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ivory-2);
    background: var(--ink-1);
    border: 1px solid var(--line-2);
    border-radius: var(--radius-sm);
    padding: 6px 10px;
    margin-left: auto;
  }
  .actions .install .prompt { color: var(--signal); margin-right: 6px; user-select: none; }

  @media (max-width: 640px) {
    .actions .install { margin-left: 0; width: 100%; overflow-x: auto; white-space: nowrap; }
  }
</style>
