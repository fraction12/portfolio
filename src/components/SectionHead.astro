---
interface Props {
  num?: string;
  name: string;
  meta?: string;
}
const { num, name, meta } = Astro.props;

function escapeHtml(s: string): string {
  return s
    .replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;').replaceAll("'", '&#39;');
}
// Escape first, then substitute — capture group is untrusted in principle.
const html = escapeHtml(name).replace(/\*(.+?)\*/g, '<em>$1</em>');
---

<header class="section-head">
  {num && <span class="section-head__num">{num}</span>}
  <h2 class="section-head__name" set:html={html}></h2>
  {meta && <p class="section-head__meta">{meta}</p>}
</header>
