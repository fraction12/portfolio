---
interface Props { current?: 'home' | 'tools' | 'writing' | 'jarvis' | 'beliefs' | 'colophon' }
const { current = 'home' } = Astro.props;

const navLinks: Array<{ href: string; label: string; key: Props['current'] }> = [
  { href: '/tools', label: 'Tools', key: 'tools' },
  { href: '/writing', label: 'Writing', key: 'writing' },
  { href: '/jarvis', label: 'Jarvis', key: 'jarvis' },
  { href: '/colophon', label: 'Colophon', key: 'colophon' }
];
---

<nav class="top-nav">
  <div class="top-nav__inner">
    <a href="/" class="top-nav__mark" aria-label="Home">Dushyant Garg</a>
    <div class="top-nav__links">
      {navLinks.map(link => (
        <a href={link.href} class:list={['top-nav__link', { active: current === link.key }]}>{link.label}</a>
      ))}
    </div>
  </div>
</nav>
