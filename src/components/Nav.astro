---
import NavLink from './NavLink.astro';
interface NavItem {
  key: 'home' | 'projects' | 'writing' | 'jarvis' | 'connect' | 'beliefs';
  href: string;
  label: string;
}
interface Props { current?: NavItem['key']; }
const { current = 'home' } = Astro.props;
const items: NavItem[] = [
  { key: 'home', href: '/', label: 'Home' },
  { key: 'projects', href: '/projects', label: 'Projects' },
  { key: 'writing', href: '/writing', label: 'Writing' },
  { key: 'jarvis', href: '/jarvis', label: 'Jarvis' },
  { key: 'beliefs', href: '/beliefs', label: 'Beliefs' },
  { key: 'connect', href: '/connect', label: 'Connect' }
];
---
<nav class="top-nav" aria-label="Primary navigation">
  <div class="top-nav-inner">
    <button class="top-nav-toggle" type="button" aria-controls="top-nav-links" aria-expanded="false">Menu</button>
    <ul id="top-nav-links" class="top-nav-links">
      {items.map((item) => (
        <li><NavLink href={item.href} active={current === item.key}>{item.label}</NavLink></li>
      ))}
    </ul>
  </div>
</nav>
<script>
  const toggle = document.querySelector('.top-nav-toggle');
  const links = document.getElementById('top-nav-links');
  if (toggle && links) {
    toggle.addEventListener('click', () => {
      const isOpen = links.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  }
</script>
