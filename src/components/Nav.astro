---
interface NavItem {
  key: 'home' | 'projects' | 'writing' | 'jarvis' | 'now' | 'connect';
  href: string;
  label: string;
}

interface Props {
  current?: NavItem['key'];
}

const { current = 'home' } = Astro.props;

const items: NavItem[] = [
  { key: 'home', href: '/', label: 'Home' },
  { key: 'projects', href: '/projects', label: 'Projects' },
  { key: 'writing', href: '/writing', label: 'Writing' },
  { key: 'jarvis', href: '/jarvis', label: 'Jarvis' },
  { key: 'now', href: '/now', label: 'Now' },
  { key: 'connect', href: '/connect', label: 'Connect' }
];
---

<nav class="top-nav" aria-label="Primary navigation">
  <div class="top-nav-inner">
    <button class="top-nav-toggle" type="button" aria-controls="top-nav-links" aria-expanded="false">
      Menu
    </button>
    <ul id="top-nav-links" class="top-nav-links">
      {items.map((item) => (
        <li>
          <a class:list={['top-nav-link', { active: current === item.key }]} href={item.href}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const toggle = document.querySelector('.top-nav-toggle');
  const links = document.getElementById('top-nav-links');

  if (toggle && links) {
    toggle.addEventListener('click', () => {
      const isOpen = links.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  }
</script>

<style>
  .top-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.95);
    border-bottom: 1px solid #1d1d1d;
  }

  .top-nav-inner {
    max-width: 980px;
    margin: 0 auto;
    padding: 0.8rem 1rem;
  }

  .top-nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .top-nav-link {
    color: #cfcfcf;
    font-size: 0.82rem;
    text-decoration: none;
  }

  .top-nav-link:hover,
  .top-nav-link:focus-visible,
  .top-nav-link.active {
    color: #f4f4f4;
  }

  .top-nav-toggle {
    display: none;
    background: transparent;
    border: 1px solid #2b2b2b;
    color: #f4f4f4;
    font: inherit;
    font-size: 0.78rem;
    padding: 0.35rem 0.65rem;
    border-radius: 6px;
    margin-bottom: 0.6rem;
  }

  @media (max-width: 720px) {
    .top-nav-toggle {
      display: inline-block;
    }

    .top-nav-links {
      display: none;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.7rem;
      padding-top: 0.2rem;
    }

    .top-nav-links.open {
      display: flex;
    }
  }
</style>
