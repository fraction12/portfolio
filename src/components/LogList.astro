---
import { getCollection } from 'astro:content';

interface Props { limit?: number }
const { limit = 5 } = Astro.props;

const entries = await getCollection('jarvis');
const sorted = entries
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
  .slice(0, limit);

function formatMonthDay(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<div class="log-list">
  {sorted.map(entry => (
    <a class="log-item" href={`/jarvis#${entry.slug}`}>
      <span class="log-date">{entry.data.date ? formatMonthDay(entry.data.date) : ''}</span>
      <span class="log-title">{entry.data.title}</span>
    </a>
  ))}
</div>

<style>
  .log-list { display: flex; flex-direction: column; gap: 2px; }
  .log-item {
    display: grid; grid-template-columns: 74px 1fr; gap: 16px;
    padding: 10px 0; border-bottom: 1px solid var(--line);
    text-decoration: none; color: inherit;
    transition: padding-left .2s, background .2s;
  }
  .log-item:last-child { border-bottom: 0; }
  .log-item:hover { padding-left: 6px; background: rgba(229,166,121,0.02); }
  .log-item:hover .log-title { color: var(--link); }
  .log-date { font-family: var(--mono); font-size: 12.5px; color: var(--dim); }
  .log-title { color: var(--ivory); transition: color .2s; }

  @media (max-width: 640px) {
    .log-item { grid-template-columns: 1fr; gap: 2px; }
  }
</style>
