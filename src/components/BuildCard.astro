---
import type { Artifact } from '../config/packages';
import { hasToolDetail } from '../config/tool-details';

interface Props {
  artifact: Artifact;
  description: string;
  context?: string;
  metric?: string | null;
  compact?: boolean;
}

const { artifact, description, context, metric = null, compact = false } = Astro.props;
const githubUrl = artifact.repo ? `https://github.com/${artifact.repo}` : null;
const detailUrl = hasToolDetail(artifact.slug) ? `/tools/${artifact.slug}` : null;
const externalUrl = artifact.url ?? githubUrl;
const host = externalUrl ? externalUrl.replace(/^https?:\/\//, '').replace(/\/$/, '') : null;
const externalLabel = artifact.url
  ? (artifact.slug === 'tradespec' ? 'Marketing site' : artifact.url.includes('github.io') ? 'Website' : host)
  : 'GitHub';
---

<article class:list={['build-card', { 'build-card--compact': compact }]}>
  <div class="build-card__main">
    <div class="build-card__head">
      <h3>
        {detailUrl ? <a class="build-card__title-link" href={detailUrl} aria-label={`Open ${artifact.name} detail page`}>{artifact.name}</a> : artifact.name}
      </h3>
      {context && <span>{context}</span>}
    </div>
    <p>{description}</p>
  </div>

  <div class="build-card__meta">
    {!compact && <span>{artifact.stack}</span>}
    {metric && <span>{metric}</span>}
    {externalUrl && (
      <a href={externalUrl} target="_blank" rel="noopener noreferrer">
        {externalLabel}
      </a>
    )}
  </div>
</article>

<style>
  .build-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(180px, 260px);
    gap: clamp(1rem, 4vw, 2rem);
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--line);
  }

  .build-card:first-child {
    border-top: 1px solid var(--line);
  }

  .build-card--compact {
    grid-template-columns: minmax(0, 1fr);
    gap: 0.75rem;
  }

  .build-card__main {
    min-width: 0;
  }

  .build-card__head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.45rem;
  }

  .build-card h3 {
    font-size: 1.04rem;
    line-height: 1.35;
  }

  .build-card__title-link {
    color: inherit;
    text-decoration: none;
  }

  .build-card__title-link:hover {
    color: var(--signal);
  }

  .build-card__head span,
  .build-card__meta {
    color: var(--dim);
    font-size: var(--type-small-size);
  }

  .build-card p {
    color: var(--ivory-2);
    line-height: 1.6;
    max-width: 68ch;
  }

  .build-card__meta {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    align-items: flex-start;
    justify-content: flex-start;
  }

  .build-card__meta a {
    color: var(--signal);
    text-decoration: none;
    font-weight: 700;
  }

  .build-card__meta a:hover {
    color: var(--signal-hov);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 720px) {
    .build-card {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }
  }
</style>
