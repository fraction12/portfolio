---
type Variant = 'signal' | 'dim' | 'agent';
interface Props { variant?: Variant; /** @deprecated use variant */ tone?: 'default' | 'amber' }
const { variant, tone } = Astro.props;
const v: Variant = variant
  ?? (tone === 'amber' ? 'signal' : tone === 'default' ? 'signal' : 'signal');
---
<span class:list={['pill', `pill--${v}`]}><slot /></span>
