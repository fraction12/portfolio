---
// Segmented control: [☼ light] [◐ system] [☾ dark].
// State is owned by the inline head script in Layout.astro; this
// component just renders the UI and dispatches a `set` on click.
---

<div class="theme-toggle" role="group" aria-label="Theme">
  <button type="button" class="theme-toggle__btn" data-theme-set="light"  aria-label="Light mode">☼</button>
  <button type="button" class="theme-toggle__btn" data-theme-set="system" aria-label="System theme">◐</button>
  <button type="button" class="theme-toggle__btn" data-theme-set="dark"   aria-label="Dark mode">☾</button>
</div>

<script>
  (() => {
    type Pref = 'light' | 'dark' | 'system';
    const STORAGE_KEY = 'theme';

    function readPref(): Pref {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (raw === 'light' || raw === 'dark' || raw === 'system') return raw;
      } catch { /* private mode */ }
      return 'system';
    }

    function resolve(pref: Pref): 'light' | 'dark' {
      if (pref === 'system') {
        return matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      return pref;
    }

    function apply(pref: Pref) {
      const actual = resolve(pref);
      document.documentElement.setAttribute('data-theme', actual);
      document.documentElement.setAttribute('data-theme-pref', pref);
      try { localStorage.setItem(STORAGE_KEY, pref); } catch {}

      const meta = document.querySelector<HTMLMetaElement>('meta[name="theme-color"]');
      if (meta) meta.content = actual === 'light' ? '#f5f2e8' : '#0c1018';

      syncUI(pref);
    }

    function syncUI(pref: Pref) {
      document.querySelectorAll<HTMLButtonElement>('[data-theme-set]').forEach(btn => {
        const active = btn.dataset.themeSet === pref;
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
    }

    function init() {
      syncUI(readPref());
      document.querySelectorAll<HTMLButtonElement>('[data-theme-set]').forEach(btn => {
        if (btn.dataset.themeToggleInit === 'true') return;
        btn.dataset.themeToggleInit = 'true';
        btn.addEventListener('click', () => {
          const next = btn.dataset.themeSet as Pref;
          apply(next);
        });
      });
    }

    init();
    document.addEventListener('astro:page-load', init);
  })();
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    margin-left: 12px;
    border: 1px solid var(--line-2);
    border-radius: var(--radius-pill);
    overflow: hidden;
    background: var(--surface-raised);
  }
  .theme-toggle__btn {
    width: 28px;
    height: 26px;
    padding: 0;
    background: transparent;
    border: 0;
    color: var(--dim);
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1;
    cursor: pointer;
    transition: color var(--motion-fast) ease, background var(--motion-fast) ease;
  }
  .theme-toggle__btn:hover { color: var(--ivory); }
  .theme-toggle__btn[aria-pressed="true"] {
    color: var(--signal);
    background: var(--signal-dim);
  }
  .theme-toggle__btn + .theme-toggle__btn {
    border-left: 1px solid var(--line-2);
  }
</style>
