---
import { BELIEFS } from '../data/beliefs';
---

<div class="b-grid">
  {BELIEFS.map(b => (
    <article class="card card--belief">
      <h4>// Rule · {b.n}</h4>
      <p set:html={b.text.replace(/\*(.+?)\*/g, '<em>$1</em>')}></p>
    </article>
  ))}
</div>

<style>
  .b-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .card--belief :global(h4) { color: var(--signal); }
  .card--belief :global(p) {
    font-family: var(--font-display);
    font-size: 1.1rem;
    line-height: 1.45;
  }
  .card--belief :global(p em) {
    font-style: italic;
    color: var(--signal);
    font-weight: 500;
  }
  @media (max-width: 1080px) { .b-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .b-grid { grid-template-columns: 1fr; } }
</style>
