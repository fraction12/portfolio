---
import type { Artifact } from '../config/packages';

type ProofItem = {
  artifact: Artifact;
  proof: string;
  note?: string;
};

interface Props {
  items: ProofItem[];
}

const { items } = Astro.props;
---

<aside class="selected-proof" aria-label="Selected proof of work">
  <div class="selected-proof__header">
    <p>Selected proof</p>
    <a href="/tools">Full catalog</a>
  </div>

  <div class="selected-proof__items">
    {items.map(({ artifact, proof, note }) => (
      <article class="proof-row">
        <div>
          <h2>{artifact.name}</h2>
          <p>{proof}</p>
        </div>
        {note && <span>{note}</span>}
      </article>
    ))}
  </div>
</aside>

<style>
  .selected-proof {
    border: 1px solid var(--line-2);
    border-radius: var(--radius-md);
    background: var(--surface-card);
    padding: 24px;
    align-self: center;
  }

  .selected-proof__header {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: baseline;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--line);
  }

  .selected-proof__header p {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--ivory);
  }

  .selected-proof__header a {
    color: var(--signal);
    font-family: var(--font-display);
    font-size: 13px;
    text-decoration: none;
    white-space: nowrap;
  }

  .selected-proof__header a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .selected-proof__items {
    display: flex;
    flex-direction: column;
  }

  .proof-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 18px;
    padding: 18px 0;
    border-bottom: 1px solid var(--line);
  }

  .proof-row:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .proof-row h2 {
    font-family: var(--font-display);
    font-size: 18px;
    line-height: 1.25;
    letter-spacing: -0.01em;
    text-transform: none;
    color: var(--ivory);
    margin-bottom: 6px;
  }

  .proof-row p {
    color: var(--ivory-2);
    font-size: 14.5px;
    line-height: 1.55;
    max-width: 46ch;
  }

  .proof-row span {
    color: var(--dim);
    font-family: var(--font-display);
    font-size: 12.5px;
    line-height: 1.35;
    text-align: right;
    max-width: 13ch;
  }

  @media (max-width: 960px) {
    .selected-proof {
      align-self: stretch;
    }
  }

  @media (max-width: 640px) {
    .selected-proof {
      padding: 20px;
    }

    .selected-proof__header {
      align-items: flex-start;
      flex-direction: column;
      gap: 6px;
    }

    .proof-row {
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .proof-row span {
      text-align: left;
      max-width: none;
    }
  }
</style>
