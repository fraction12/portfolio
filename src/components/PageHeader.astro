---
import { escapeHtmlWithEm } from '../lib/escape-html';
import BackButton from './BackButton.astro';

interface Props {
  kicker?: string;
  backButton?: boolean;
  backHref?: string;
  backLabel?: string;
  title: string;
  lede?: string;
}
const { kicker, backButton = false, backHref = '/', backLabel = 'Back', title, lede } = Astro.props;

const titleHtml = escapeHtmlWithEm(title);
const ledeHtml = lede ? escapeHtmlWithEm(lede) : null;
---

<header class="page-header">
  {backButton ? (
    <BackButton href={backHref} label={backLabel} />
  ) : kicker && (
    <p class="page-header__kicker">{kicker}</p>
  )}
  <h1 class="page-header__title" set:html={titleHtml}></h1>
  {ledeHtml && <p class="page-header__lede" set:html={ledeHtml}></p>}
</header>
