---
interface Props {
  primary?: { label: string; href: string };
  secondary?: { label: string; href: string };
}
const {
  primary = { label: 'View the work', href: '/tools' },
  secondary = { label: 'Read the writing', href: '#writing' },
} = Astro.props;
---

<header class="intro">
  <div class="intro__content">
    <p class="role">Product Manager / Builder</p>
    <h1 class="name">Dushyant Garg</h1>
    <p class="summary">
      I build practical AI products and product systems for messy workflows,
      fast-moving teams, and users who need useful software more than impressive demos.
    </p>

    <div class="ctas">
      <a class="btn btn--primary" href={primary.href}>{primary.label}</a>
      <a class="btn btn--ghost" href={secondary.href}>{secondary.label}</a>
    </div>
  </div>

  <figure class="portrait">
    <img src="/dushyant-garg-avatar.jpg" alt="Dushyant Garg" width="160" height="160" loading="eager" decoding="async" />
  </figure>
</header>

<style>
  .intro {
    display: grid;
    grid-template-columns: minmax(0, 760px) 144px;
    gap: clamp(2rem, 7vw, 6rem);
    align-items: start;
    padding: clamp(4.5rem, 10vw, 7rem) 0 clamp(3rem, 7vw, 5rem);
  }
  .intro__content { min-width: 0; }
  .role {
    font-family: var(--font-display);
    font-size: var(--type-small-size);
    font-weight: 600;
    letter-spacing: 0;
    text-transform: none;
    color: var(--dim);
    margin-bottom: 16px;
  }
  .name {
    font-family: var(--font-display);
    font-size: var(--type-hero-name-size);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 0.98;
    color: var(--ivory);
    margin-bottom: 24px;
  }
  .summary {
    font-family: var(--font-display);
    font-size: clamp(1.16rem, 2vw, 1.35rem);
    line-height: 1.65;
    color: var(--ivory-2);
    max-width: 60ch;
    margin-bottom: 32px;
  }
  .ctas {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .portrait {
    margin-top: 4px;
    width: 144px;
    aspect-ratio: 1;
    border-radius: 999px;
    overflow: hidden;
    border: 1px solid var(--line-2);
    background: var(--ink-2);
  }
  .portrait img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 640px) {
    .intro {
      grid-template-columns: 1fr;
      gap: 1.2rem;
      padding: 3.25rem 0 2.5rem;
    }
    .portrait {
      order: -1;
      width: 78px;
      margin-top: 0;
    }
    .summary { font-size: 16px; }
  }
</style>
