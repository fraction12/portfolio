---
interface Props {
  primary?: { label: string; href: string };
  secondary?: { label: string; href: string };
}
const {
  primary = { label: 'See the tools', href: '/tools' },
  secondary = { label: 'Read the writing', href: '/writing' },
} = Astro.props;
---

<header class="intro">
  <h1 class="name">Dushyant Garg<span class="cursor" aria-hidden="true"></span></h1>
  <p class="mission">
    I build tools that make AI agents <em>usable</em> — memory that sticks,
    orchestration that doesn't deadlock, observability that doesn't lie.
    Open-source by default, shipped to real customers.
  </p>

  <div class="ctas">
    <a class="btn btn--primary" href={primary.href}>{primary.label} →</a>
    <a class="btn btn--ghost" href={secondary.href}>{secondary.label} ↗</a>
  </div>

  <div class="socials">
    <a href="https://github.com/fraction12" target="_blank" rel="noopener">github</a>
    <span class="dot" aria-hidden="true">·</span>
    <a href="https://linkedin.com/in/dushyantgarg" target="_blank" rel="noopener">linkedin</a>
    <span class="dot" aria-hidden="true">·</span>
    <a href="https://dushyantg.substack.com" target="_blank" rel="noopener">substack</a>
    <span class="dot" aria-hidden="true">·</span>
    <a href="mailto:hi@dushyantgarg.com">email</a>
  </div>
</header>

<style>
  .intro {
    padding: 72px 0 40px;
    max-width: 72ch;
  }
  .name {
    font-family: var(--font-display);
    font-size: var(--type-hero-name-size);
    font-weight: 750;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--ivory);
    margin-bottom: 24px;
  }
  /* Subtle blinking cursor after the name — blinks for ~2.4s on first
     paint, then fades out. One moment of "this site is alive" before it
     settles into a static heading. */
  .cursor {
    display: inline-block;
    width: 0.5ch;
    height: 1em;
    margin-left: 6px;
    background: var(--signal);
    vertical-align: text-bottom;
    animation:
      cursorBlink 1s step-end 3,
      heroFadeOut 0.4s ease 2.4s forwards;
  }
  @keyframes heroFadeOut {
    to { opacity: 0; width: 0; margin-left: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cursor { display: none; }
  }
  .mission {
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.55;
    color: var(--ivory-2);
    max-width: 54ch;
    margin-bottom: 32px;
  }
  .mission em {
    font-style: italic;
    font-weight: 500;
    color: var(--signal);
  }
  .ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }
  .socials {
    display: flex;
    gap: 10px;
    align-items: center;
    font-size: 14px;
    color: var(--dim);
    flex-wrap: wrap;
  }
  .socials a {
    color: var(--dim);
    text-decoration: none;
    transition: color var(--motion-fast) ease;
  }
  .socials a:hover { color: var(--signal); }
  .socials .dot { color: var(--dim-2); }

  @media (max-width: 640px) {
    .intro { padding: 48px 0 28px; }
    .mission { font-size: 17px; }
  }
</style>
