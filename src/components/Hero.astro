---
const socials = [
  { label: 'GitHub', href: 'https://github.com/fraction12' },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/dushyantgarg' },
  { label: 'Substack', href: 'https://dushyantg.substack.com' },
  { label: 'npm', href: 'https://www.npmjs.com/~fraction12' }
];
---

<section id="hero" class="hero">
  <div class="hero-inner">
    <p class="hero-kicker">Dushyant Garg</p>
    <h1 class="hero-name">Full-stack builder.</h1>
    <p class="hero-title">I ship products end-to-end, from strategy docs to working code.</p>

    <nav class="hero-links" aria-label="Social links">
      {socials.map((social) => (
        <a class="hero-link" href={social.href} target="_blank" rel="noopener noreferrer">
          {social.label}
        </a>
      ))}
    </nav>
  </div>
</section>
