---
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/base.css';
import '../styles/animations.css';

interface Props {
  title?: string;
  description?: string;
  current?: 'home' | 'tools' | 'writing' | 'skills' | 'contact';
  ogImage?: string;
  /** When true, adds Person + WebSite JSON-LD for the canonical portfolio. Use on the home page only. */
  includeIdentitySchema?: boolean;
}

const {
  title = 'Dushyant Garg',
  description = 'Dushyant Garg — Product Manager and builder working on practical AI products, product systems, and open-source tools.',
  current = 'home',
  ogImage = '/og-default.png',
  includeIdentitySchema = false,
} = Astro.props;

const siteOrigin = (Astro.site ?? new URL('https://dushyantgarg.com')).origin;
const canonical = new URL(Astro.url.pathname, siteOrigin).toString();
const ogTitle = title.includes('Dushyant Garg') ? title : `${title} — Dushyant Garg`;

// Verification tokens are read from build-time env. Import.meta.env.PUBLIC_*
// is inlined into the client bundle — safe because verification tokens are
// already public-facing meta tags, not secrets.
const googleVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION as string | undefined;
const bingVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION as string | undefined;

const personSchema = includeIdentitySchema
  ? {
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Dushyant Garg',
      url: siteOrigin + '/',
      description:
        'Product Manager and builder working on practical AI products, product systems, and open-source tools.',
      sameAs: [
        'https://github.com/fraction12',
        'https://linkedin.com/in/dushyantgarg',
        'https://dushyantg.substack.com',
      ],
    }
  : null;

const websiteSchema = includeIdentitySchema
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Dushyant Garg',
      url: siteOrigin + '/',
      description:
        'Canonical portfolio of Dushyant Garg — product work, open-source builds, and writing.',
      author: {
        '@type': 'Person',
        name: 'Dushyant Garg',
        url: siteOrigin + '/',
      },
    }
  : null;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#080807" />
  <script is:inline>
    // Dark-only theme guard. Runs before paint and before Astro swaps so
    // stale stored light-mode preferences cannot affect the UI.
    (function () {
      var state = window.__portfolioThemeState || (window.__portfolioThemeState = {});
      function forceDark(doc) {
        doc.documentElement.setAttribute('data-theme', 'dark');
        doc.documentElement.setAttribute('data-theme-pref', 'dark');
        var meta = doc.querySelector('meta[name="theme-color"]');
        if (meta) meta.setAttribute('content', '#080807');
        try {
          localStorage.removeItem('portfolio-theme-v2');
        } catch (e) {}
      }
      forceDark(document);

      if (!state.installed) {
        state.installed = true;

        document.addEventListener('astro:before-swap', function (ev) {
          forceDark(ev.newDocument);
        });
      }
    })();
  </script>
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={new URL(ogImage, canonical).toString()} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, canonical).toString()} />
  {googleVerification && <meta name="google-site-verification" content={googleVerification} />}
  {bingVerification && <meta name="msvalidate.01" content={bingVerification} />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Advertises the llms.txt summary (https://llmstxt.org) so agents
       fetching any page can discover the machine-readable portfolio
       digest without guessing at /llms.txt by convention. -->
  <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM-friendly summary" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  {personSchema && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema).replace(/</g, '\\u003c')} />
  )}
  {websiteSchema && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema).replace(/</g, '\\u003c')} />
  )}
  <ClientRouter fallback="animate" />
</head>
<body>
  <Nav current={current} />

  <main class="page-main" transition:animate="fade" transition:name="page-content">
    <slot />
  </main>

  <Footer />
  <Analytics />
  <SpeedInsights />

  <script>
    import '../scripts/portfolio-motion';
  </script>
</body>
</html>
