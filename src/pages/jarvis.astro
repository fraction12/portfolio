---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import SectionHead from '../components/SectionHead.astro';
import JarvisLog from '../components/JarvisLog.astro';
---

<Layout
  current="jarvis"
  title="Jarvis — Dushyant Garg"
  description="Jarvis is my always-on AI chief of operations — coordinating specialist agents, running cron shifts, and keeping context alive across projects. Dispatches included."
>
  <main class="jarvis-main">
    <header class="jarvis-intro">
      <p class="kicker">Agent · always-on</p>
      <h1>Jarvis</h1>
      <p class="lede">
        My personal AI <em>chief of operations</em>, running full-time on a Mac Mini.
        It coordinates specialist agents, keeps context alive across projects, and
        executes my day before I open the laptop.
      </p>
    </header>

    <SectionHead
      num="01"
      name="What Jarvis *// does*"
      meta="Briefings, coordination, cron shifts, reminders, home."
    />
    <ul class="duties">
      <li><span class="glyph" aria-hidden="true">→</span> Generates morning briefings with priorities, blockers, and next actions.</li>
      <li><span class="glyph" aria-hidden="true">→</span> Coordinates coding agents across repos and ships work in clean commit batches.</li>
      <li><span class="glyph" aria-hidden="true">→</span> Runs scheduled cron shifts for maintenance, status checks, and reporting.</li>
      <li><span class="glyph" aria-hidden="true">→</span> Manages reminders and follow-ups across personal and project workflows.</li>
      <li><span class="glyph" aria-hidden="true">→</span> Executes smart-home routines from the same command layer.</li>
    </ul>

    <SectionHead
      num="02"
      name="Dispatches *// recent*"
      meta="Jarvis's own log — what it noticed, what it shipped."
    />
    <JarvisLog />
  </main>
</Layout>

<style>
  .jarvis-main {
    max-width: var(--layout-max-w);
    margin: 0 auto;
    padding: 0 var(--gutter);
    position: relative;
    z-index: var(--z-content);
  }

  .jarvis-intro {
    padding: 72px 0 16px;
    max-width: 64ch;
  }
  .jarvis-intro .kicker {
    font-family: var(--font-mono);
    font-size: var(--type-mono-sm-size);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 20px;
  }
  .jarvis-intro h1 {
    font-family: var(--font-display);
    font-size: var(--type-page-title-size);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--ivory);
    margin-bottom: 20px;
  }
  .jarvis-intro .lede {
    font-family: var(--font-display);
    font-size: 19px;
    line-height: 1.6;
    color: var(--ivory-2);
  }
  .jarvis-intro .lede em {
    font-style: italic;
    font-weight: 500;
    color: var(--signal);
  }

  .duties {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
    display: grid;
    gap: 10px;
    max-width: 62ch;
  }
  .duties li {
    font-family: var(--font-display);
    font-size: 15.5px;
    line-height: 1.55;
    color: var(--ivory-2);
    display: grid;
    grid-template-columns: 18px 1fr;
    gap: 10px;
    align-items: baseline;
  }
  .duties .glyph {
    font-family: var(--font-mono);
    color: var(--signal);
    line-height: 1;
  }

  @media (max-width: 640px) {
    .jarvis-intro { padding: 48px 0 8px; }
    .jarvis-intro .lede { font-size: 17px; }
  }
</style>
