---
// SSR: render on request, edge-cached 5 min fresh + 30 min stale-while-revalidate.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Spotlight from '../components/Spotlight.astro';
import CommitStrip from '../components/CommitStrip.astro';
import BeliefsExcerpt from '../components/BeliefsExcerpt.astro';
import ToolCard from '../components/ToolCard.astro';
import WritingBlock from '../components/WritingBlock.astro';
import SectionHead from '../components/SectionHead.astro';
import Contact from '../components/Contact.astro';
import { artifacts, type Artifact } from '../config/packages';
import { loadSignalData } from '../lib/data';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=1800');

const data = await loadSignalData();

function metricFor(a: Artifact): { metric: string | null; placeholder: string } {
  if (a.metricOverride) return { metric: a.metricOverride, placeholder: '' };
  if (a.npmName) {
    const d = data.npm.packages[a.npmName]?.downloadsLastMonth;
    if (typeof d === 'number') return { metric: `↓ ${d.toLocaleString()} / mo`, placeholder: '' };
    return { metric: null, placeholder: '[npm stats pending]' };
  }
  if (a.pypiName) {
    const d = data.pypi.packages[a.pypiName]?.downloadsLastMonth;
    if (typeof d === 'number') return { metric: `↓ ${d.toLocaleString()} / mo`, placeholder: '' };
    return { metric: null, placeholder: '[pypi stats pending]' };
  }
  return { metric: null, placeholder: '' };
}

const featured = artifacts.find(a => a.slug === 'potato') ?? artifacts[0];

const homeFeaturedSlugs = ['tradespec', 'clawk', 'potato'];
const homeFeatured = homeFeaturedSlugs
  .map(s => artifacts.find(a => a.slug === s))
  .filter((a): a is Artifact => Boolean(a));

const totalTools = artifacts.length;

const latestCommit = data.commits[0];
---

<Layout
  current="home"
  title="Dushyant Garg"
  description="Dushyant Garg — builds open-source tools that make AI agents usable. Memory, orchestration, observability. Shipped to real customers."
  includeIdentitySchema
>
  <main class="sd-main">

    <div class="hero-split">
      <Hero />
      <Spotlight artifact={featured} kicker="Featured" />
    </div>

    {latestCommit && (
      <div class="sd-commit-strip">
        <CommitStrip commit={latestCommit} />
      </div>
    )}

    <section id="why" class="section-split">
      <SectionHead
        num="01"
        name="Why *// two rules*"
        meta="Operating principles I test nightly — every agent in the stack reads them first."
      />
      <div class="section-split__content">
        <BeliefsExcerpt />
      </div>
    </section>

    <section id="tools" class="section-split">
      <SectionHead
        num="02"
        name="Tools *// three I'm proud of*"
        meta="A slice from the toolkit — full browser on /tools."
      />
      <div class="section-split__content">
        <div class="home-tools-list">
          {homeFeatured.map(a => {
            const { metric, placeholder } = metricFor(a);
            return <ToolCard artifact={a} metric={metric} metricPlaceholder={placeholder} />;
          })}
        </div>
        <a class="more-link" href="/tools">See all {totalTools} tools →</a>
      </div>
    </section>

    <section id="writing" class="section-split">
      <SectionHead
        num="03"
        name="Writing *// dispatches*"
        meta="Weekly notes on building with AI agents, shipping fast, learning in public."
      />
      <div class="section-split__content">
        <WritingBlock essays={data.essays} limit={3} />
      </div>
    </section>

    <section id="contact" class="section-split">
      <SectionHead
        num="04"
        name="Contact *// reach out*"
        meta="Subscribe to the writing, or DM. I read everything."
      />
      <div class="section-split__content">
        <Contact />
      </div>
    </section>

  </main>
</Layout>

<style>
  .sd-main {
    margin: 0 auto;
    padding: 0 32px;
    position: relative;
    z-index: var(--z-content);
  }

  .sd-commit-strip {
    padding: 8px 0 16px;
  }

  .home-tools-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .more-link {
    display: inline-block;
    margin-top: 14px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--signal);
    text-decoration: none;
  }
  .more-link:hover { text-decoration: underline; text-underline-offset: 3px; }

  @media (max-width: 640px) {
    .sd-main { padding: 0 22px; }
  }
</style>
