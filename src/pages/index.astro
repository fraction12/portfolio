---
// SSR: render on request, edge-cached 5 min fresh + 30 min stale-while-revalidate.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FlagshipWorkCard from '../components/FlagshipWorkCard.astro';
import WritingBlock from '../components/WritingBlock.astro';
import Contact from '../components/Contact.astro';
import { getToolDetail, type ToolDetail } from '../config/tool-details';
import { loadSignalData } from '../lib/data';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=1800');

const data = await loadSignalData();
const homeWorkSlugs = ['openspec-studio', 'tradespec', 'potato'] as const;
const homeWorkDetails = homeWorkSlugs
  .map(slug => getToolDetail(slug))
  .filter((detail): detail is ToolDetail => Boolean(detail));
const homeWorkProof: Record<string, string> = {
  'openspec-studio':
    'A visual workbench for spec-driven development: changes, tasks, validation, archive readiness, and runner state in one place.',
  tradespec:
    'Customer-facing AI workflow for estimating teams, with evidence-linked outputs and a clear private-alpha boundary.',
  potato:
    'A local multi-agent cockpit for running Codex, Claude Code, and CLI agents with roles, shared task state, and project-aware panes.',
};

---

<Layout
  current="home"
  title="Dushyant Garg"
  description="Dushyant Garg — Product Manager and builder working on practical AI products, product systems, and open-source tools."
  ogImage="/og/home.png"
  includeIdentitySchema
>
  <div class="page-shell home-shell">
    <Hero github={data.github} />

    <section id="work" class="home-work-section" data-work-section data-home-work-section>
      <div class="home-flagship">
        <h2 class="home-section-title" data-home-work-slot>Highlighted work</h2>
        <div class="home-flagship__grid">
          {homeWorkDetails.map(detail => (
            <div class="home-flagship__slot" data-home-work-slot>
              <FlagshipWorkCard
                detail={detail}
                proof={homeWorkProof[detail.slug] ?? detail.summary}
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="writing" class="home-writing-section" data-home-scroll-section>
      <div class="home-writing">
        <h2 class="home-section-title" data-home-scroll-slot>Writing</h2>
        <div data-home-scroll-slot>
          <WritingBlock essays={data.essays} limit={3} />
        </div>
      </div>
    </section>

    <section id="contact" class="home-contact-section" data-home-scroll-section>
      <div class="home-contact">
        <h2 class="home-section-title" data-home-scroll-slot>Contact</h2>
        <div data-home-scroll-slot>
          <Contact />
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .home-shell {
    position: relative;
    z-index: var(--z-content);
  }

  .home-work-section {
    padding: clamp(1.5rem, 4vw, 3rem) 0 var(--section-pad);
  }

  .home-flagship {
    display: grid;
    gap: 1.25rem;
  }

  .home-section-title {
    font-size: clamp(0.95rem, 1.4vw, 1.12rem);
    line-height: 1.2;
    letter-spacing: 0;
    text-align: center;
  }

  .home-flagship__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(16rem, 1fr));
    gap: 1rem;
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-snap-type: x proximity;
    scrollbar-width: thin;
  }

  .home-flagship__grid :global(.flagship-card) {
    height: 100%;
  }

  .home-flagship__slot {
    display: grid;
    scroll-snap-align: start;
  }

  .home-writing-section {
    padding: var(--section-pad) 0;
  }

  .home-writing {
    display: grid;
    gap: 1.25rem;
  }

  .home-contact-section {
    padding: var(--section-pad) 0;
  }

  .home-contact {
    display: grid;
    gap: 1.25rem;
    justify-items: center;
    text-align: center;
  }

  .home-contact :global(.contact) {
    justify-items: center;
  }

  .home-contact :global(.contact .btn) {
    justify-self: center;
  }
</style>
