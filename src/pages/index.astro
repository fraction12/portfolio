---
// SSR: render on request, edge-cached 5 min fresh + 30 min stale-while-revalidate.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FlagshipWorkCard from '../components/FlagshipWorkCard.astro';
import WritingBlock from '../components/WritingBlock.astro';
import SectionHead from '../components/SectionHead.astro';
import Contact from '../components/Contact.astro';
import { flagshipWorkDetails, flagshipWorkProof } from '../config/featured-work';
import { loadSignalData } from '../lib/data';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=1800');

const data = await loadSignalData();

---

<Layout
  current="home"
  title="Dushyant Garg"
  description="Dushyant Garg — Product Manager and builder working on practical AI products, product systems, and open-source tools."
  ogImage="/og/home.png"
  includeIdentitySchema
>
  <div class="page-shell home-shell">
    <Hero github={data.github} />

    <section id="work" class="section-split" data-work-section>
      <SectionHead name="Work" meta="Selected builds that show the range: product workflow, open-source infrastructure, and tools for evaluating what gets shipped." />
      <div class="section-split__content home-flagship">
        <div class="home-flagship__grid">
          {flagshipWorkDetails.map(detail => (
            <FlagshipWorkCard
              detail={detail}
              proof={flagshipWorkProof[detail.slug] ?? detail.summary}
            />
          ))}
        </div>
        <a class="text-link" href="/tools">See the broader work catalog</a>
      </div>
    </section>

    <section id="writing" class="section-split">
      <SectionHead name="Writing" meta="Notes on product work, AI systems, and what becomes clearer after shipping." />
      <div class="section-split__content">
        <WritingBlock essays={data.essays} limit={3} />
      </div>
    </section>

    <section id="contact" class="section-split">
      <SectionHead name="Contact" meta="A direct way to reach me." />
      <div class="section-split__content">
        <Contact />
      </div>
    </section>
  </div>
</Layout>

<style>
  .home-shell {
    position: relative;
    z-index: var(--z-content);
  }

  .home-flagship {
    display: grid;
    gap: 1rem;
  }

  .home-flagship__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .text-link {
    display: inline-flex;
    justify-self: start;
    margin-top: 1rem;
    color: var(--signal);
    font-size: var(--type-small-size);
    font-weight: 700;
    text-decoration: none;
  }

  .text-link:hover {
    color: var(--signal-hov);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 760px) {
    .home-flagship__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
