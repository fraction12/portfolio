---
// SSR: render on request, edge-cached 5 min fresh + 30 min stale-while-revalidate.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import BuildCard from '../components/BuildCard.astro';
import WritingBlock from '../components/WritingBlock.astro';
import SectionHead from '../components/SectionHead.astro';
import Contact from '../components/Contact.astro';
import { artifacts, type Artifact } from '../config/packages';
import { loadSignalData } from '../lib/data';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=1800');

const data = await loadSignalData();

const selectedWorkCopy: Partial<Record<string, { description: string; context: string }>> = {
  tradespec: {
    description: 'AI bid-review workspace for construction estimators, built around plan evidence and customer feedback.',
    context: 'Product',
  },
  'spec-ui': {
    description: 'Spec-to-prototype compiler for turning product plans into deterministic, reviewable interfaces.',
    context: 'Open source',
  },
  microcanvas: {
    description: 'Small viewer/runtime for inspecting UI artifacts with real browser checks instead of static screenshots.',
    context: 'Open source',
  },
  agenttk: {
    description: 'Typed command primitives for safer agent-facing tools and clearer operating contracts.',
    context: 'Open source',
  },
};

const homeFeaturedSlugs = ['tradespec', 'spec-ui', 'microcanvas', 'agenttk'];
const homeFeatured = homeFeaturedSlugs
  .map(s => artifacts.find(a => a.slug === s))
  .filter((a): a is Artifact => Boolean(a));
---

<Layout
  current="home"
  title="Dushyant Garg"
  description="Dushyant Garg — Product Manager and builder working on practical AI products, product systems, and open-source tools."
  ogImage="/og/home.svg"
  includeIdentitySchema
>
  <div class="page-shell home-shell">
    <Hero />

    <section id="work" class="section-split">
      <SectionHead name="Work" meta="Selected builds that show the range: product workflow, open-source infrastructure, and tools for evaluating what gets shipped." />
      <div class="section-split__content work-list">
        {homeFeatured.map(a => {
          const copy = selectedWorkCopy[a.slug] ?? { description: a.description, context: a.kind };
          return (
            <BuildCard
              artifact={a}
              description={copy.description}
              context={copy.context}
              compact
            />
          );
        })}
        <a class="text-link" href="/tools">See the broader work catalog</a>
      </div>
    </section>

    <section id="writing" class="section-split">
      <SectionHead name="Writing" meta="Notes on product work, AI systems, and what becomes clearer after shipping." />
      <div class="section-split__content">
        <WritingBlock essays={data.essays} limit={3} />
      </div>
    </section>

    <section id="contact" class="section-split">
      <SectionHead name="Contact" meta="A direct way to reach me." />
      <div class="section-split__content">
        <Contact />
      </div>
    </section>
  </div>
</Layout>

<style>
  .home-shell {
    position: relative;
    z-index: var(--z-content);
  }

  .work-list {
    display: grid;
  }

  .text-link {
    display: inline-flex;
    justify-self: start;
    margin-top: 1rem;
    color: var(--signal);
    font-size: var(--type-small-size);
    font-weight: 700;
    text-decoration: none;
  }

  .text-link:hover {
    color: var(--signal-hov);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
