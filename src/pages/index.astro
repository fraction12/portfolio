---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Writing from '../components/Writing.astro';
import Projects from '../components/Projects.astro';
import Connect from '../components/Connect.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import JarvisSpotlight from '../components/JarvisSpotlight.astro';
---

<Layout current="home" title="Dushyant Garg">
  <div class="container">
    <Hero />

    <section class="section-stack" aria-labelledby="featured-writing-title">
      <h2 id="featured-writing-title" class="section-title reveal">Featured Writing<span class="dot">.</span></h2>
      <Writing limit={3} />
    </section>

    <section class="section-stack" aria-labelledby="projects-title">
      <h2 id="projects-title" class="section-title reveal">Projects<span class="dot">.</span></h2>
      <Projects />
    </section>

    <section class="section-stack" aria-labelledby="jarvis-title">
      <JarvisSpotlight />
    </section>

    <section class="section-stack" aria-labelledby="connect-title">
      <h2 id="connect-title" class="section-title reveal">Connect<span class="dot">.</span></h2>
      <Connect />
      <NewsletterSignup className="reveal" />
    </section>
  </div>

  <script>
    import '../scripts/connect.js';
  </script>
</Layout>
