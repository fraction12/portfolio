---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Writing from '../components/Writing.astro';
import Projects from '../components/Projects.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import JarvisSpotlight from '../components/JarvisSpotlight.astro';
import Section from '../components/Section.astro';
---

<Layout current="home" title="Dushyant Garg" description="PM who builds AI tools. Open-source projects, writing, and live dispatches from Jarvis.">
  <div class="container">
    <Hero />

    <Section title="Featured Writing" id="featured-writing-title">
      <Writing limit={3} />
    </Section>

    <Section title="Projects" id="projects-title">
      <Projects />
    </Section>

    <Section>
      <JarvisSpotlight />
    </Section>

    <Section>
      <NewsletterSignup className="reveal" />
    </Section>
  </div>

  <script>
    import '../scripts/connect.js';
  </script>
</Layout>
