---
// SSR so supporting package metrics can stay fresh without rebuilds.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import WorkGridCard from '../components/WorkGridCard.astro';
import ProjectDetailSurface from '../components/ProjectDetailSurface.astro';
import { CATEGORY_ORDER, type Artifact } from '../config/packages';
import { flagshipWorkSlugs } from '../config/featured-work';
import { toolDetails, type ToolDetail } from '../config/tool-details';
import { loadSignalData } from '../lib/data';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=1800');

const data = await loadSignalData();

function metricFor(a: Artifact): string | null {
  if (a.metricOverride) return a.metricOverride;
  if (a.npmName) {
    const d = data.npm.packages[a.npmName]?.downloadsLastMonth;
    if (typeof d === 'number') return `${d.toLocaleString()} npm downloads last month`;
  }
  if (a.pypiName) {
    const d = data.pypi.packages[a.pypiName]?.downloadsLastMonth;
    if (typeof d === 'number') return `${d.toLocaleString()} PyPI downloads last month`;
  }
  return null;
}

const catalogCopy: Record<string, string> = {
  tradespec: 'Specialty-contractor estimate review: plan evidence, scope findings, and review-ready bid outputs in one workflow.',
  agentsense: 'Memory layer for agent systems that need entity extraction, relationships, and durable context across sessions.',
  agentrem: 'Reminder and follow-up primitives for agents that need time, keyword, condition, recurrence, and priority handling.',
  agenttk: 'Typed CLI primitives for building agent-facing tools with safer commands and clearer discovery.',
  starglass: 'Observation layer that turns stdout, events, and tool calls into one readable timeline.',
  potato: 'Local orchestration surface for running coding agents in real PTYs with roles and coordination boundaries.',
  agentplan: 'SQLite-backed task board for multiple agents that need atomic claims, dependencies, and shared priorities.',
  octocheck: 'Resident GitHub App controller that queues trusted local CI, agent review, and guarded fix lanes behind policy checks.',
  'spec-ui': 'Compiler that turns structured product specs into deterministic prototypes for human and agent review.',
  microcanvas: 'Viewer/runtime for opening, inspecting, and testing UI artifacts created by agents or code tools.',
  'openspec-studio': 'Local-first desktop workbench for inspecting OpenSpec changes, specs, validation, archive readiness, and runner dispatch.',
  clawk: 'macOS menu bar for monitoring OpenClaw sessions, heartbeats, memory, and background runs.',
  deepclean: 'Local repo evidence, source-safe PR context, and guarded cleanup lanes for codebases that need safer structure work.',
  explain: 'Codebase-to-architecture documentation generator for teams that need to understand what changed.',
  openrank: 'Public benchmark platform for comparing agent performance on timed puzzles.',
  wireflow: 'Lightweight planning and wireframing surface for meetings, product flows, and implementation sketches.',
  'agent-office': 'Spatial interface experiment for watching agent work as activity, not just logs.',
  hunt: 'Personal CRM for roles, companies, applications, and agent-assisted lead triage.',
  eat: 'Kitchen inventory and recipe experiment with receipt scanning, RSS ingestion, and inventory-aware matching.',
  'vault-mind': 'Parked local-model experiment for talking to a second brain through a CLI.',
};

const flagshipOrder = new Map<string, number>(flagshipWorkSlugs.map((slug, index) => [slug, index]));

function hasCardMedia(detail: ToolDetail): boolean {
  if (detail.demo.status !== 'ready') return false;
  if (detail.demo.type === 'video') return Boolean(detail.demo.poster);
  return Boolean(detail.demo.poster ?? detail.demo.src);
}

function compareEditorialPriority(a: ToolDetail, b: ToolDetail): number {
  const aFlagship = flagshipOrder.get(a.slug);
  const bFlagship = flagshipOrder.get(b.slug);

  if (aFlagship !== undefined && bFlagship !== undefined) return aFlagship - bFlagship;
  if (aFlagship !== undefined) return -1;
  if (bFlagship !== undefined) return 1;

  return CATEGORY_ORDER.indexOf(a.artifact.category) - CATEGORY_ORDER.indexOf(b.artifact.category)
    || a.artifact.order - b.artifact.order;
}

const orderedDetails: ToolDetail[] = [...toolDetails].sort((a, b) => {
  if (hasCardMedia(a) !== hasCardMedia(b)) return hasCardMedia(a) ? -1 : 1;
  return compareEditorialPriority(a, b);
});

const pageSize = 9;
const requestedPage = Number(Astro.url.searchParams.get('page') ?? '1');
const totalPages = Math.max(1, Math.ceil(orderedDetails.length / pageSize));
const currentPage = Number.isInteger(requestedPage) && requestedPage >= 1 && requestedPage <= totalPages
  ? requestedPage
  : 1;
const pageStart = (currentPage - 1) * pageSize;
const visibleDetails = orderedDetails.slice(pageStart, pageStart + pageSize);
const visibleRangeStart = pageStart + 1;
const visibleRangeEnd = pageStart + visibleDetails.length;
const pageHref = (page: number) => page === 1 ? '/tools' : `/tools?page=${page}`;
---

<Layout
  current="tools"
  title="Work — Dushyant Garg"
  description="Selected product work, open-source systems, and experiments by Dushyant Garg."
  ogImage="/og/work.png"
>
  <div class="page-shell">
    <div class="page-split">
      <PageHeader
        kicker="Work"
        title="Builds, products, and systems"
        lede="Selected products, open-source systems, and experiments with context on what each does, where it stands, and why it matters."
      />
    </div>

    <section class="catalog-section" aria-label="Work catalog">
      <div class="catalog-grid">
        {visibleDetails.map((detail, index) => (
          <WorkGridCard
            detail={detail}
            description={catalogCopy[detail.slug] ?? detail.summary}
            metric={metricFor(detail.artifact)}
            selected={index === 0}
          />
        ))}
      </div>

      <section class="project-reader" aria-live="polite" aria-label="Selected work details">
        {visibleDetails.map((detail, index) => (
          <ProjectDetailSurface detail={detail} selected={index === 0} />
        ))}
      </section>

      <nav class="pagination" aria-label="Work catalog pages">
        <p>Showing {visibleRangeStart}-{visibleRangeEnd} of {orderedDetails.length}</p>
        <div class="pagination__controls">
          {currentPage > 1 ? (
            <a href={pageHref(currentPage - 1)} rel="prev">Previous</a>
          ) : (
            <span aria-disabled="true">Previous</span>
          )}

          {Array.from({ length: totalPages }, (_, index) => {
            const page = index + 1;
            return page === currentPage ? (
              <span class="pagination__page" aria-current="page">{page}</span>
            ) : (
              <a class="pagination__page" href={pageHref(page)}>{page}</a>
            );
          })}

          {currentPage < totalPages ? (
            <a href={pageHref(currentPage + 1)} rel="next">Next</a>
          ) : (
            <span aria-disabled="true">Next</span>
          )}
        </div>
      </nav>
    </section>
  </div>

  <script>
    function initProjectReader() {
      const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-project-select]'));
      const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-project-panel]'));
      if (!buttons.length || !panels.length) return;

      const reader = document.querySelector<HTMLElement>('.project-reader');
      const select = (slug: string, shouldScroll: boolean) => {
        buttons.forEach(button => {
          const active = button.dataset.projectSelect === slug;
          button.setAttribute('aria-pressed', String(active));
          button.closest('[data-motion-card]')?.classList.toggle('work-grid-card--selected', active);
        });

        panels.forEach(panel => {
          panel.hidden = panel.dataset.projectPanel !== slug;
        });

        if (shouldScroll) {
          history.replaceState(null, '', `#project-${slug}`);
          reader?.scrollIntoView({ block: 'start', behavior: 'smooth' });
        }
      };

      buttons.forEach(button => {
        button.addEventListener('click', () => {
          const slug = button.dataset.projectSelect;
          if (slug) select(slug, true);
        });
      });

      const hashSlug = window.location.hash.replace(/^#project-/, '');
      const initial = buttons.find(button => button.dataset.projectSelect === hashSlug)
        ?? buttons.find(button => button.getAttribute('aria-pressed') === 'true')
        ?? buttons[0];
      if (initial.dataset.projectSelect) select(initial.dataset.projectSelect, false);
    }

    document.addEventListener('astro:page-load', initProjectReader);
  </script>
</Layout>

<style>
  .catalog-section {
    padding: 0 0 var(--section-pad);
  }

  .catalog-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    min-width: 0;
  }

  .project-reader {
    scroll-margin-top: calc(var(--layout-nav-h) + 1.5rem);
  }

  :global(.work-grid-card--selected) {
    border-color: color-mix(in srgb, var(--signal) 52%, var(--line));
    background: color-mix(in srgb, var(--surface-raised) 82%, var(--signal-dim));
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.25rem;
    color: var(--dim);
    font-size: var(--type-small-size);
  }

  .pagination__controls {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .pagination a,
  .pagination span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.2rem;
    min-height: 2.2rem;
    padding: 0 0.7rem;
    border: 1px solid var(--line);
    color: var(--ivory-2);
    text-decoration: none;
  }

  .pagination a:hover,
  .pagination a:focus-visible,
  .pagination__page[aria-current='page'] {
    border-color: color-mix(in srgb, var(--signal) 60%, var(--line));
    color: var(--signal);
  }

  .pagination span[aria-disabled='true'] {
    color: color-mix(in srgb, var(--dim) 55%, transparent);
  }

  @media (max-width: 980px) {
    .catalog-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .catalog-grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .pagination {
      display: grid;
      gap: 0.8rem;
    }

    .pagination__controls {
      flex-wrap: wrap;
    }
  }
</style>
