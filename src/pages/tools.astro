---
// SSR so supporting package metrics can stay fresh without rebuilds.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import SectionHead from '../components/SectionHead.astro';
import BuildCard from '../components/BuildCard.astro';
import FlagshipWorkCard from '../components/FlagshipWorkCard.astro';
import { artifacts, type Artifact } from '../config/packages';
import { getToolDetail, type ToolDetail } from '../config/tool-details';
import { loadSignalData } from '../lib/data';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=1800');

const data = await loadSignalData();

function metricFor(a: Artifact): string | null {
  if (a.metricOverride && a.slug === 'tradespec') return a.metricOverride;
  if (a.npmName) {
    const d = data.npm.packages[a.npmName]?.downloadsLastMonth;
    if (typeof d === 'number') return `${d.toLocaleString()} npm downloads last month`;
  }
  if (a.pypiName) {
    const d = data.pypi.packages[a.pypiName]?.downloadsLastMonth;
    if (typeof d === 'number') return `${d.toLocaleString()} PyPI downloads last month`;
  }
  return null;
}

const catalogCopy: Record<string, string> = {
  tradespec: 'Specialty-contractor estimate review: plan evidence, scope findings, and review-ready bid outputs in one workflow.',
  agentsense: 'Memory layer for agent systems that need entity extraction, relationships, and durable context across sessions.',
  agentrem: 'Reminder and follow-up primitives for agents that need time, keyword, condition, recurrence, and priority handling.',
  agenttk: 'Typed CLI primitives for building agent-facing tools with safer commands and clearer discovery.',
  starglass: 'Observation layer that turns stdout, events, and tool calls into one readable timeline.',
  potato: 'Local orchestration surface for running coding agents in real PTYs with roles and coordination boundaries.',
  agentplan: 'SQLite-backed task board for multiple agents that need atomic claims, dependencies, and shared priorities.',
  'spec-ui': 'Compiler that turns structured product specs into deterministic prototypes for human and agent review.',
  microcanvas: 'Viewer/runtime for opening, inspecting, and testing UI artifacts created by agents or code tools.',
  'openspec-studio': 'Local-first desktop workbench for inspecting OpenSpec changes, specs, validation, archive readiness, and runner dispatch.',
  clawk: 'macOS menu bar for monitoring OpenClaw sessions, heartbeats, memory, and background runs.',
  explain: 'Codebase-to-architecture documentation generator for teams that need to understand what changed.',
  openrank: 'Public benchmark platform for comparing agent performance on timed puzzles.',
  wireflow: 'Lightweight planning and wireframing surface for meetings, product flows, and implementation sketches.',
  'agent-office': 'Spatial interface experiment for watching agent work as activity, not just logs.',
  hunt: 'Personal CRM for roles, companies, applications, and agent-assisted lead triage.',
  eat: 'Kitchen inventory and recipe experiment with receipt scanning, RSS ingestion, and inventory-aware matching.',
  'vault-mind': 'Parked local-model experiment for talking to a second brain through a CLI.',
};

const flagshipSlugs = ['tradespec', 'openspec-studio', 'microcanvas', 'agentplan'];
const flagshipSet = new Set(flagshipSlugs);
const flagshipProof: Record<string, string> = {
  tradespec:
    'Customer-facing AI workflow for estimating teams, with evidence-linked outputs and a clear private-alpha boundary.',
  'openspec-studio':
    'A visual workbench for spec-driven development: changes, tasks, validation, archive readiness, and runner state in one place.',
  microcanvas:
    'A display surface for agent-created artifacts, built around real rendering, verification, and screenshot evidence.',
  agentplan:
    'A shared task board for AI-native teams, with local durable state and claimable work for multiple agents.',
};
const flagshipDetails = flagshipSlugs
  .map(slug => getToolDetail(slug))
  .filter((detail): detail is ToolDetail => Boolean(detail));

const groups: Array<{ name: string; meta: string; items: Artifact[] }> = [
  {
    name: 'Supporting systems',
    meta: 'Infrastructure, tools, and primitives that support the larger product thesis.',
    items: artifacts.filter(a => a.category !== 'products' && a.category !== 'experiments' && !flagshipSet.has(a.slug)),
  },
  {
    name: 'Experiments',
    meta: 'Smaller builds and parked ideas that still produced useful lessons.',
    items: artifacts.filter(a => a.category === 'experiments'),
  },
].filter(group => group.items.length > 0);
---

<Layout
  current="tools"
  title="Work — Dushyant Garg"
  description="Selected product work, open-source systems, and experiments by Dushyant Garg."
  ogImage="/og/work.svg"
>
  <div class="page-shell">
    <div class="page-split">
      <PageHeader
        kicker="Work"
        title="Builds, products, and systems"
        lede="A broader catalog of product work and open-source systems. The homepage is edited; this page is for the people who want to inspect the range."
      />
    </div>

    <section class="section-split" id="flagship-work">
      <SectionHead name="Flagship work" meta="The strongest proof surfaces: product workflow, spec workbench, visual QA, and agent coordination." />
      <div class="section-split__content flagship-grid">
        {flagshipDetails.map(detail => (
          <FlagshipWorkCard
            detail={detail}
            proof={flagshipProof[detail.slug] ?? detail.summary}
          />
        ))}
      </div>
    </section>

    {groups.map(group => (
      <section class="section-split" id={`work-${group.name.toLowerCase().replaceAll(' ', '-')}`}>
        <SectionHead name={group.name} meta={group.meta} />
        <div class="section-split__content catalog-list">
          {group.items.map(a => (
            <BuildCard
              artifact={a}
              description={catalogCopy[a.slug] ?? a.description}
              context={a.kind}
              metric={metricFor(a)}
            />
          ))}
        </div>
      </section>
    ))}
  </div>
</Layout>

<style>
  .flagship-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .catalog-list {
    display: grid;
  }

  @media (max-width: 760px) {
    .flagship-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
