---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import ProjectDetailSurface from '../../components/ProjectDetailSurface.astro';
import { toolDetails, type ToolDetail } from '../../config/tool-details';

export function getStaticPaths() {
  return toolDetails.map(detail => ({
    params: { slug: detail.slug },
    props: { detail },
  }));
}

interface Props {
  detail: ToolDetail;
}

const { detail } = Astro.props;
const { artifact } = detail;
const pageTitle = `${artifact.name} - Work - Dushyant Garg`;
const pageDescription = detail.summary;
const detailOgImages: Record<string, string> = {
  tradespec: '/og/tradespec.png',
  microcanvas: '/og/microcanvas.png',
  'openspec-studio': '/og/openspec-studio.png',
  'spec-ui': '/og/spec-ui.png',
};
---

<Layout
  current="tools"
  title={pageTitle}
  description={pageDescription}
  ogImage={detailOgImages[artifact.slug] ?? '/og/work.png'}
>
  <div class="page-shell detail-shell">
    <ProjectDetailSurface detail={detail} mode="page" />
  </div>
</Layout>

<style>
  .detail-shell {
    padding-top: clamp(1rem, 3vw, 2rem);
  }
</style>
