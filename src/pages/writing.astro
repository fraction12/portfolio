---
import Layout from '../layouts/Layout.astro';
import Writing from '../components/Writing.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
---

<Layout current="writing" title="Writing — Dushyant Garg">
  <div class="container">
    <section class="page-intro">
      <h1 class="page-title reveal">Writing<span class="dot">.</span></h1>
    </section>

    <section class="section-stack">
      <Writing />
    </section>

    <section class="section-stack section-tight">
      <NewsletterSignup className="reveal" />
    </section>
  </div>
</Layout>
