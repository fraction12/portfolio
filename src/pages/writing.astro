---
// SSR: Substack essays update independently of deploys.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Writing from '../components/Writing.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=1800');
---

<Layout
  current="writing"
  title="Writing — Dushyant Garg"
  description="Essays by Dushyant Garg on product work, AI systems, and building useful software."
  ogImage="/og/writing.png"
>
  <div class="page-shell">
    <div class="page-split">
      <PageHeader
        kicker="Writing"
        title="Notes from the work"
        lede="Essays on product work, AI systems, and what becomes clearer after shipping."
      />
    </div>

    <section class="writing-section" aria-label="Essays">
      <div>
        <Writing />
      </div>
    </section>

    <section class="section-split" aria-label="Subscribe">
      <div class="section-split__content writing-section__wide">
        <NewsletterSignup />
      </div>
    </section>
  </div>
</Layout>

<style>
  .writing-section {
    padding: 0 0 var(--section-pad);
  }

  .writing-section__wide {
    grid-column: 1 / -1;
  }
</style>
