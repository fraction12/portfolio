---
// SSR: Substack essays update independently of deploys.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import SectionHead from '../components/SectionHead.astro';
import Writing from '../components/Writing.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=1800');
---

<Layout
  current="writing"
  title="Writing — Dushyant Garg"
  description="Essays by Dushyant Garg on product work, AI systems, and building useful software."
  ogImage="/og/writing.svg"
>
  <div class="page-shell">
    <div class="page-split">
      <PageHeader
        kicker="Writing"
        title="Notes from the work"
        lede="Essays on product work, AI systems, and what becomes clearer after shipping."
      />
    </div>

    <section class="section-split">
      <SectionHead name="Essays" meta="Selected recent writing on product work and AI systems." />
      <div class="section-split__content">
        <Writing />
      </div>
    </section>

    <section class="section-split">
      <SectionHead name="Subscribe" meta="Get the next essay by email." />
      <div class="section-split__content">
        <NewsletterSignup />
      </div>
    </section>
  </div>
</Layout>
