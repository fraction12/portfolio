---
// SSR so the metrics table stays accurate without rebuilds.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import SectionHead from '../components/SectionHead.astro';
import { loadSignalData } from '../lib/data';
const data = await loadSignalData();

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=1800');

const rows = [
  { label: 'Last commit', value: `${data.lastCommit.sha.slice(0, 7)} · ${data.lastCommitRelative}`, source: 'github graphql · viewer.repositories.history' },
  { label: 'Commits (7d)', value: data.github.commits7d ?? '—', source: 'github graphql · contributionsCollection' },
  { label: 'Commits (30d)', value: data.github.commits30d ?? '—', source: 'github graphql · contributionsCollection' },
  { label: 'Stars (all repos)', value: data.github.totalStars ?? '—', source: 'github rest · /users/{user}/repos' },
  { label: 'npm downloads (30d)', value: Object.keys(data.npm.packages).length === 0 ? '—' : Object.values(data.npm.packages).reduce((t, p) => t + p.downloadsLastMonth, 0).toLocaleString(), source: 'api.npmjs.org/downloads/point/last-month' },
  { label: 'pypi downloads (30d)', value: Object.keys(data.pypi.packages).length === 0 ? '—' : Object.values(data.pypi.packages).reduce((t, p) => t + p.downloadsLastMonth, 0).toLocaleString(), source: 'pypistats.org/api/packages/{pkg}/recent' },
  { label: 'Essays', value: data.essays.length, source: 'dushyantg.substack.com/feed (rss)' },
  { label: 'Shift summaries', value: data.shifts.length, source: 'local git log + 4-hour gap clustering' }
];

const totalSources = new Set(rows.map(r => r.source.split(' ·')[0])).size;
const now = new Date();
const updatedAt = `${now.toISOString().slice(0, 10)} · ${now.toISOString().slice(11, 16)}Z`;
---

<Layout
  current="colophon"
  title="Colophon — Dushyant Garg"
  description="Every metric on dushyantgarg.com mapped to its public source — GitHub, npm, PyPI, Substack — with no made-up figures."
>
  <main class="page-main-split">

    <div class="page-split">
      <PageHeader
        kicker="Sources · receipts"
        title="Colophon *// every metric*"
        lede="Every number on this site maps to a public source. If a source is unwired, you see an italic placeholder — never a made-up figure."
      />
      <aside class="page-aside">
        <div class="page-aside__stat"><b>{rows.length}</b><span class="label">metrics tracked</span></div>
        <div class="page-aside__stat"><b>{totalSources}</b><span class="label">public sources</span></div>
        <div class="updated">as of {updatedAt}</div>
      </aside>
    </div>

    <section class="section-split">
      <SectionHead
        num="01"
        name="Metrics *// live*"
        meta="Each row fetches from a public API on request. No caching hidden from view."
      />
      <div class="section-split__content">
        <table>
          <thead><tr><th>Metric</th><th>Current value</th><th>Source</th></tr></thead>
          <tbody>
            {rows.map(r => (
              <tr>
                <td>{r.label}</td>
                <td class="v">{r.value}</td>
                <td class="s">{r.source}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

  </main>
</Layout>

<style>
  .page-main-split {
    margin: 0 auto;
    padding: 0 32px;
    position: relative;
    z-index: var(--z-content);
  }
  .updated {
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--dim-2);
    letter-spacing: 0.04em;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid var(--line-2);
  }
  th, td { padding: 14px 18px; border-bottom: 1px solid var(--line); text-align: left; vertical-align: top; }
  tr:last-child td { border-bottom: 0; }
  th { color: var(--signal); font-family: var(--font-mono); font-size: 11.5px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 500; background: rgba(229,166,121,0.04); }
  td { font-family: var(--font-display); font-size: 15px; color: var(--ivory-2); }
  td.v { font-family: var(--font-mono); color: var(--ivory); font-weight: 500; }
  td.s { font-family: var(--font-mono); color: var(--dim); font-size: 12.5px; }
  tr:hover td { background: rgba(255,255,255,0.015); }

  @media (max-width: 640px) {
    .page-main-split { padding: 0 22px; }
    table { font-size: 13px; }
    th, td { padding: 10px 12px; }
  }
</style>
